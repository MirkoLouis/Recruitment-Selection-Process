{{> header}}

<div class="glass-panel p-4 mb-0 shadow-sm rounded-4 d-print-none">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-semibold">Dashboard</h2>
    </div>
    
    <!-- Dashboard Tabs -->
    <ul class="nav nav-pills mb-2 gap-2" id="dashboardTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link {{#unless selectedPosition}}{{#unless showMasterlist}}active{{/unless}}{{/unless}} fw-bold px-4 py-2 rounded-pill shadow-sm" id="metrics-tab" data-bs-toggle="pill" data-bs-target="#metrics" type="button" role="tab"><i class="bi bi-graph-up me-2"></i> Metrics</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold px-4 py-2 rounded-pill shadow-sm {{#if selectedPosition}}active{{/if}}" id="categories-tab" data-bs-toggle="pill" data-bs-target="#categories" type="button" role="tab"><i class="bi bi-diagram-3 me-2"></i> Vacancy Setup</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold px-4 py-2 rounded-pill shadow-sm {{#if showMasterlist}}active{{/if}}" id="masterlist-tab" data-bs-toggle="pill" data-bs-target="#masterlist" type="button" role="tab"><i class="bi bi-people-fill me-2"></i> Masterlist</button>
        </li>
    </ul>

    <div class="tab-content" id="dashboardTabsContent">
        <!-- Metrics Tab -->
        <div class="tab-pane fade {{#unless selectedPosition}}{{#unless showMasterlist}}show active{{/unless}}{{/unless}}" id="metrics" role="tabpanel">
            <div class="row g-4 mb-4">
                <div class="col-md-12">
                    <div class="card border-0 glass-panel shadow-sm rounded-4 h-100" style="background: linear-gradient(135deg, rgba(13,110,253,0.1) 0%, rgba(13,110,253,0.05) 100%); border-left: 5px solid #0d6efd !important;">
                        <div class="card-body p-4 d-flex align-items-center">
                            <div class="display-4 text-primary fw-bold me-4"><i class="bi bi-briefcase-fill"></i></div>
                            <div>
                                <h3 class="fw-bold mb-1">{{totalVacantCount}} / {{totalPositionsCount}}</h3>
                                <p class="text-muted mb-0">Total Vacant Positions Across All Categories</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <h5 class="fw-bold mb-3 text-muted"><i class="bi bi-bar-chart-fill me-2"></i>Vacancies per Category</h5>
            <div class="row g-4">
                {{#each groupedPositions}}
                <div class="col-md-6 col-lg-3">
                    <div class="card border-0 glass-panel shadow-sm rounded-4 h-100 p-2 {{#if this.hasVacancy}}border-start border-4 border-success{{else}}border-start border-4 border-secondary opacity-75{{/if}}" style="transition: transform 0.2s; cursor: default;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                        <div class="card-body p-2">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="fw-bold mb-0 text-truncate" title="{{this.categoryName}}">{{this.categoryName}}</h6>
                                <span class="badge {{#if this.hasVacancy}}bg-success{{else}}bg-secondary{{/if}} rounded-pill" style="font-size: 0.7rem;">
                                    {{#if this.hasVacancy}}Active{{else}}No Vacancy{{/if}}
                                </span>
                            </div>
                            <div class="mt-4 d-flex align-items-end justify-content-between">
                                <div>
                                    <h2 class="fw-bold mb-0 {{#if this.hasVacancy}}text-success{{else}}text-muted{{/if}}">{{this.vacantCount}}</h2>
                                    <small class="text-muted">Vacant / {{this.totalCount}} Total</small>
                                </div>
                                <i class="bi bi-pie-chart-fill fs-2 text-muted opacity-25"></i>
                            </div>
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>
        </div>

        <!-- Categories Tab -->
        <div class="tab-pane fade {{#if selectedPosition}}show active{{/if}}" id="categories" role="tabpanel">
            <div class="glass-panel p-4 rounded-4 shadow-sm h-100 position-relative">
                
                <!-- Search & Filter -->
                <div class="mb-3">
                    <form class="row g-2" onsubmit="event.preventDefault(); filterVacancyTable();">
                        <div class="col-md-4">
                            <div class="input-group glass-panel h-100">
                                <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                                <input type="text" id="vacancySearch" class="form-control bg-transparent border-0 shadow-none" placeholder="Search position name..." onkeyup="filterVacancyTable()">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="glass-panel h-100 px-2 py-1">
                                <select id="vacancyCategory" class="form-select bg-transparent border-0 shadow-none" onchange="filterVacancyTable()">
                                    <option value="">All Categories</option>
                                    {{#each groupedPositions}}
                                        <option value="{{this.categoryName}}">{{this.categoryName}}</option>
                                    {{/each}}
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="glass-panel h-100 px-2 py-1">
                                <select id="vacancyStatus" class="form-select bg-transparent border-0 shadow-none" onchange="filterVacancyTable()">
                                    <option value="">All Statuses</option>
                                    <option value="vacant">Vacant</option>
                                    <option value="non-vacant">Non-Vacant</option>
                                </select>
                            </div>
                        </div>
                    </form>
                </div>

                <table class="table table-hover align-middle mb-0 border-light" id="vacancyTable">
                    <thead>
                        <tr>
                            <th class="fw-bold">Position Name</th>
                            <th class="text-center fw-bold">Vacancy</th>
                            <th class="text-center fw-bold">Plantilla</th>
                            <th class="text-center fw-bold">Slots</th>
                            <th class="text-center fw-bold">Position Info</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each groupedPositions}}
                            <tr class="table-light vacancy-category-group" data-category="{{this.categoryName}}">
                                <td colspan="5" class="fw-bold text-primary bg-primary bg-opacity-10 border-0">{{this.categoryName}}</td>
                            </tr>
                            {{#each this.positions}}
                            <tr class="vacancy-row" data-category="{{../this.categoryName}}" data-title="{{this.title}}">
                                <td class="fw-semibold">{{this.title}}</td>
                                <td class="text-center">
                                    <div class="form-check form-switch d-flex justify-content-center">
                                        <input class="form-check-input vacancy-toggle cursor-pointer" type="checkbox" data-id="{{this.id}}" {{#if this.in_vacancy}}checked{{/if}} style="transform: scale(1.3);">
                                    </div>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-success shadow-sm plantilla-setup-btn rounded-pill px-3" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#plantillaModal"
                                        data-id="{{this.id}}"
                                        data-title="{{this.title}}"
                                        data-count="{{this.vacancyCount}}"
                                        data-plantilla="{{this.plantillaItem}}"
                                        id="plantilla-btn-{{this.id}}"
                                        {{#unless this.in_vacancy}}disabled{{/unless}}>
                                        <i class="bi bi-list-ol me-1"></i> Setup
                                    </button>
                                </td>
                                <td class="text-center fw-bold text-secondary" id="slot-count-{{this.id}}">{{#if this.in_vacancy}}{{this.vacancyCount}}{{else}}0{{/if}}</td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-primary shadow-sm position-info-btn rounded-pill px-3" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#positionInfoModal"
                                        data-id="{{this.id}}"
                                        data-title="{{this.title}}"
                                        data-vacancy="{{this.vacancyAnnouncement}}"
                                        data-plantilla="{{this.plantillaItem}}"
                                        data-salary="{{this.salaryGrade}}"
                                        data-monthly="{{this.monthlySalary}}"
                                        data-edu="{{this.qsEducation}}"
                                        data-train="{{this.qsTraining}}"
                                        data-exp="{{this.qsExperience}}"
                                        data-elig="{{this.qsEligibility}}">
                                        <i class="bi bi-info-circle me-1"></i> Info
                                    </button>
                                </td>
                            </tr>
                            {{/each}}
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Masterlist Tab -->
        <div class="tab-pane fade {{#if showMasterlist}}show active{{/if}}" id="masterlist" role="tabpanel">
            <div class="glass-panel p-4 rounded-4 shadow-sm h-100 position-relative">
                <div class="mb-3">
                    <form method="GET" action="/dashboard" class="row g-2">
                        <input type="hidden" name="tab" value="masterlist">
                        <div class="col-md-6">
                            <div class="input-group glass-panel h-100 shadow-sm">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                                <input type="text" name="q" class="form-control border-start-0 ps-0" placeholder="Search by name or tracking number..." value="{{searchQuery}}">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="glass-panel h-100 px-2 py-1 shadow-sm bg-white">
                                <select name="position" class="form-select border-0 shadow-none bg-transparent" onchange="this.form.submit()">
                                    <option value="">All Positions</option>
                                    {{#each positionList}}
                                        <option value="{{this}}" {{#if (eq this ../positionFilter)}}selected{{/if}}>{{this}}</option>
                                    {{/each}}
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100 h-100 fw-bold shadow-sm">Search</button>
                        </div>
                    </form>
                </div>

                <div class="rounded-4 overflow-hidden shadow-sm border border-light">
                    <table class="table table-hover align-middle mb-0 bg-white">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Tracking #</th>
                                <th>Applicant Name</th>
                                <th>Category</th>
                                <th>Position</th>
                                <th>Current Status / Step</th>
                                <th class="text-center pe-4">Info</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each applicants}}
                            <tr>
                                <td class="ps-4"><span class="badge bg-secondary font-monospace">{{this.applicationCode}}</span></td>
                                <td class="fw-medium applicant-name-display-{{this.id}}">{{this.name}}</td>
                                <td>{{this.category}}</td>
                                <td>{{this.position}}</td>
                                <td>
                                    {{#if (eq this.status 'PENDING')}}<span class="badge bg-warning text-dark">Step 1: Pending</span>{{/if}}
                                    {{#if (eq this.status 'QUALIFIED')}}<span class="badge bg-success">Step 1: Qualified</span>{{/if}}
                                    {{#if (eq this.status 'DISQUALIFIED')}}<span class="badge bg-danger">Step 1: Disqualified</span>{{/if}}
                                    {{#if (eq this.status 'WAITING_FOR_ASSESSMENT')}}<span class="badge bg-info text-dark">Step 2: Deliberation</span>{{/if}}
                                    {{#if (eq this.status 'ASSESSED')}}<span class="badge bg-primary">Step 3: Assessment</span>{{/if}}
                                    {{#if (eq this.status 'WAITING')}}<span class="badge bg-secondary">Step 4: Requirements</span>{{/if}}
                                    {{#if (eq this.status 'ASSIGNED')}}<span class="badge bg-success shadow-sm border border-light">Step 5: Assigned</span>{{/if}}
                                </td>
                                <td class="text-center pe-4">
                                    <button class="btn btn-sm btn-outline-primary shadow-sm rounded-circle px-2 py-1" onclick="openInfoModal({{this.id}})" title="Personal Info"><i class="bi bi-person-lines-fill"></i></button>
                                </td>
                            </tr>
                            {{else}}
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2 text-secondary opacity-50"></i>
                                    No applicants found matching the criteria.
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>

                <nav aria-label="Page navigation" class="mt-4">
                    <ul class="pagination flex-wrap justify-content-center mb-0">
                        {{#each pagination}}
                            {{#if this.isEllipsis}}
                                <li class="page-item disabled"><span class="page-link border-0 bg-transparent text-muted">...</span></li>
                            {{else}}
                                <li class="page-item {{#if this.isCurrent}}active{{/if}}">
                                    <a class="page-link mx-1 {{#if this.isCurrent}}shadow-sm{{/if}} {{#if @first}}page-first{{else if @last}}page-last{{else}}rounded-circle{{/if}}" href="{{this.url}}">{{this.page}}</a>
                                </li>
                            {{/if}}
                        {{/each}}
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div> <!-- End container-fluid -->

<!-- Modals (Hidden from print) -->
<div class="d-print-none">
    <!-- Add Applicant Modal -->
    <div class="modal fade glass-modal" id="addApplicantModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-bottom-0 bg-primary bg-opacity-10 text-primary pb-3">
                    <h5 class="modal-title fw-bold"><i class="bi bi-person-plus-fill me-2"></i><span id="addApplicantModalTitle">New Applicant Wizard</span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="addApplicantForm">
                        <!-- Step 0: Category & Position -->
                        <div id="wizardStep0">
                            <h6 class="mb-3 text-center fw-bold">Select Applicant Category</h6>
                            <div class="row g-3 mb-3" id="categorySelection">
                                <div class="col-6"><button type="button" class="btn btn-outline-primary w-100 py-3 fw-semibold" onclick="selectCategory('Teaching')">Teaching</button></div>
                                <div class="col-6"><button type="button" class="btn btn-outline-primary w-100 py-3 fw-semibold" onclick="selectCategory('Related Teaching')">Related Teaching</button></div>
                                <div class="col-6"><button type="button" class="btn btn-outline-primary w-100 py-3 fw-semibold" onclick="selectCategory('School Administration')">School Administration</button></div>
                                <div class="col-6"><button type="button" class="btn btn-outline-primary w-100 py-3 fw-semibold" onclick="selectCategory('Non-Teaching')">Non-Teaching</button></div>
                            </div>
                            
                            <div id="positionSelection" class="d-none">
                                <div class="d-flex align-items-center mb-3">
                                    <button type="button" class="btn btn-sm btn-light me-2" onclick="backToCategories()"><i class="bi bi-arrow-left"></i></button>
                                    <h6 class="mb-0 fw-bold" id="selectedCategoryTitle">Select Position</h6>
                                </div>
                                <div class="list-group" id="positionList">
                                    <!-- Populated via JS -->
                                </div>
                            </div>
                        </div>

                        <!-- Step 1: Personal Info -->
                        <div id="wizardStep1" class="d-none">
                            <div class="d-flex align-items-center mb-3">
                                <button type="button" class="btn btn-sm btn-light me-2" onclick="backToPositions()"><i class="bi bi-arrow-left"></i></button>
                                <h6 class="mb-0 fw-bold text-primary">Personal Information</h6>
                            </div>
                            <input type="hidden" name="category" id="wizardCategory">
                            <input type="hidden" name="position" id="wizardPosition">
                            <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">First Name</label>
                                <input type="text" class="form-control" name="firstName" required placeholder="e.g. John">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Middle Name</label>
                                <input type="text" class="form-control" name="middleName" placeholder="e.g. Smith">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Last Name</label>
                                <input type="text" class="form-control" name="lastName" required placeholder="e.g. Doe">
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Address</label>
                                <input type="text" class="form-control" name="address">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Age</label>
                                <input type="number" class="form-control" name="age">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Sex</label>
                                <select class="form-select" name="sex">
                                    <option value="">Select...</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Civil Status</label>
                                <input type="text" class="form-control" name="civilStatus">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Religion</label>
                                <input type="text" class="form-control" name="religion">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Disability</label>
                                <input type="text" class="form-control" name="disability">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Ethnic Group</label>
                                <input type="text" class="form-control" name="ethnicGroup">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" name="emailAddress" placeholder="Email">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Contact No.</label>
                                <input type="text" class="form-control" name="contactNo" placeholder="Contact">
                            </div>
                        </div>
                        <div class="d-flex justify-content-end mt-4">
                            <button type="submit" class="btn btn-primary">Save & Next: Education <i class="bi bi-arrow-right"></i></button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Qualify Modal -->
    <div class="modal fade glass-modal" id="qualifyModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">Qualify Applicant</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="qualifyForm">
                        <input type="hidden" id="qualifyId">
                        <p>Qualifying <strong id="qualifyName" class="text-primary"></strong></p>
                        <button type="submit" class="btn btn-success w-100">Confirm Qualification</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Score Modal -->
    <div class="modal fade glass-modal" id="scoreModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">Input Interview Score</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="scoreForm">
                        <input type="hidden" id="scoreId">
                        <p>Applicant: <strong id="scoreName" class="text-info"></strong></p>
                        <div class="mb-3">
                            <label class="form-label">Score (0-100)</label>
                            <input type="number" class="form-control form-control-lg text-center fw-bold fs-3" id="interviewScore" min="0" max="100" required>
                        </div>
                        <button type="submit" class="btn btn-info text-white w-100">Submit Assessment</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Requirements Modal -->
    <div class="modal fade glass-modal" id="requirementsModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">Requirements Checklist</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="requirementsModalBody">
                    <!-- Populated via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Assign Modal -->
    <div class="modal fade glass-modal" id="assignModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">Assign Office / School</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="assignForm">
                        <input type="hidden" id="assignId">
                        <p>Assigning: <strong id="assignName" class="text-success"></strong></p>
                        <div class="mb-4">
                            <label class="form-label">Assigned Office / School</label>
                            <input type="text" class="form-control" id="assignedOffice" required placeholder="e.g. IT Department">
                        </div>
                        <button type="submit" class="btn btn-success text-white w-100">Confirm Assignment</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Personal Info Modal -->
    <div class="modal fade glass-modal" id="infoModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">Personal Information</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="infoModalBody">
                    <!-- Populated via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Education Modal -->
    <div class="modal fade glass-modal" id="eduModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold" id="eduModalTitle">Education Records</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="eduModalBody">
                    <!-- Populated via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Training Modal -->
    <div class="modal fade glass-modal" id="trainModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold" id="trainModalTitle">Training Seminars</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="trainModalBody">
                    <!-- Populated via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Experience Modal -->
    <div class="modal fade glass-modal" id="expModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold" id="expModalTitle">Work Experience</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="expModalBody">
                    <!-- Populated via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Eligibility Modal -->
    <div class="modal fade glass-modal" id="eligModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
