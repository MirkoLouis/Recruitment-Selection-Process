{{> header}}

<div class="glass-panel p-4 mb-0 shadow-sm rounded-4 d-print-none">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-semibold mb-0">Dashboard</h2>
        
        <!-- Dashboard Tabs -->
        <ul class="nav nav-pills gap-2" id="dashboardTabs" role="tablist">
            {{#unless (eq user.role "superadmin")}}
            <li class="nav-item" role="presentation">
                <button class="nav-link {{#unless selectedPosition}}{{#unless showMasterlist}}{{#unless showCategories}}{{#unless showBackup}}active{{/unless}}{{/unless}}{{/unless}}{{/unless}} fw-bold px-4 py-2 rounded-pill shadow-sm" id="metrics-tab" data-bs-toggle="pill" data-bs-target="#metrics" type="button" role="tab"><i class="bi bi-graph-up me-2"></i> Metrics</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold px-4 py-2 rounded-pill shadow-sm {{#if selectedPosition}}active{{/if}} {{#if showCategories}}active{{/if}}" id="categories-tab" data-bs-toggle="pill" data-bs-target="#categories" type="button" role="tab"><i class="bi bi-diagram-3 me-2"></i> Vacancy Setup</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold px-4 py-2 rounded-pill shadow-sm {{#if showMasterlist}}active{{/if}}" id="masterlist-tab" data-bs-toggle="pill" data-bs-target="#masterlist" type="button" role="tab"><i class="bi bi-people-fill me-2"></i> Masterlist</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold px-4 py-2 rounded-pill shadow-sm {{#if showBackup}}active{{/if}}" id="backup-tab" data-bs-toggle="pill" data-bs-target="#backup" type="button" role="tab"><i class="bi bi-cloud-arrow-down-fill me-2"></i> Backup</button>
            </li>
            {{/unless}}
            {{#if (eq user.role "admin")}}
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold px-4 py-2 rounded-pill shadow-sm" id="users-tab" data-bs-toggle="pill" data-bs-target="#users" type="button" role="tab"><i class="bi bi-person-gear me-2"></i> Manage Users</button>
            </li>

            {{else if (eq user.role "superadmin")}}
            <li class="nav-item" role="presentation">
                <button class="nav-link active fw-bold px-4 py-2 rounded-pill shadow-sm" id="users-tab" data-bs-toggle="pill" data-bs-target="#users" type="button" role="tab"><i class="bi bi-person-gear me-2"></i> Manage Users</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold px-4 py-2 rounded-pill shadow-sm" id="logs-tab" data-bs-toggle="pill" data-bs-target="#logs" type="button" role="tab"><i class="bi bi-journal-text me-2"></i> Logs</button>
            </li>
            {{/if}}
        </ul>
    </div>
    
    <div class="tab-content" id="dashboardTabsContent">
        {{#unless (eq user.role "superadmin")}}
            {{> dashboard_metrics}}
            {{> dashboard_categories}}
            {{> dashboard_masterlist}}
            {{> dashboard_backup}}
        {{/unless}}

        {{#if (eq user.role "admin")}}
            {{> dashboard_users}}

        {{else if (eq user.role "superadmin")}}
            {{> dashboard_users}}
            {{> dashboard_logs}}
        {{/if}}
    </div>
</div> <!-- End container-fluid -->

<!-- Modals (Hidden from print) -->
{{> index_modals}}

        </main>
    </div> <!-- End d-flex wrapper -->
    

    <script src="/js/requirements.js"></script>
<script src="/js/qualifications.js"></script>
<script src="/js/assignment.js"></script>
<script src="/js/applicantDetails.js"></script>
<script src="/js/documents.js"></script>
<script src="/js/assessment.js?v=2"></script>
<script src="/js/admin.js"></script>
<script src="/js/main.js"></script>
<script src="/js/modal_stack.js"></script>
<script src="/js/paginationHelper.js"></script>
<!-- Chart JS -->
<script src="/chartjs/chart.umd.js"></script>
<!-- Choices JS -->
<script src="/choices.js/scripts/choices.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        document.querySelectorAll('.searchable-select').forEach(function(el) {
            new Choices(el, {
                searchEnabled: true,
                itemSelectText: '',
                shouldSort: false,
                position: 'bottom'
            });
        });
    });
</script>
{{> dashboard_scripts}}
    {{> global_toasts}}
    <script src="/js/utils.js"></script>
</body>
</html>
