{{> header}}

<div class="glass-panel p-4 mb-0 shadow-sm rounded-4 d-print-none">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-semibold">Dashboard</h2>
    </div>
    
    <!-- Dashboard Tabs -->
    <ul class="nav nav-pills mb-2 gap-2" id="dashboardTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link {{#unless selectedPosition}}{{#unless showMasterlist}}{{#unless showCategories}}active{{/unless}}{{/unless}}{{/unless}} fw-bold px-4 py-2 rounded-pill shadow-sm" id="metrics-tab" data-bs-toggle="pill" data-bs-target="#metrics" type="button" role="tab"><i class="bi bi-graph-up me-2"></i> Metrics</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold px-4 py-2 rounded-pill shadow-sm {{#if selectedPosition}}active{{/if}} {{#if showCategories}}active{{/if}}" id="categories-tab" data-bs-toggle="pill" data-bs-target="#categories" type="button" role="tab"><i class="bi bi-diagram-3 me-2"></i> Vacancy Setup</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold px-4 py-2 rounded-pill shadow-sm {{#if showMasterlist}}active{{/if}}" id="masterlist-tab" data-bs-toggle="pill" data-bs-target="#masterlist" type="button" role="tab"><i class="bi bi-people-fill me-2"></i> Masterlist</button>
        </li>
    </ul>

    <div class="tab-content" id="dashboardTabsContent">
        {{> dashboard_metrics}}

        {{> dashboard_categories}}

        {{> dashboard_masterlist}}
    </div>
</div> <!-- End container-fluid -->

<!-- Modals (Hidden from print) -->
{{> dashboard_modals}}

        </main>
    </div> <!-- End d-flex wrapper -->
    
    <!-- Bootstrap Bundle with Popper -->
    <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/js/applicantWizard.js"></script>
    <script src="/jspdf/dist/jspdf.umd.min.js"></script>
    <script src="/js/pdfGenerator.js?v=1.1"></script>
    <script src="/js/requirements.js"></script>
<script src="/js/qualifications.js"></script>
<script src="/js/scores.js"></script>
<script src="/js/assignment.js"></script>
<script src="/js/applicantDetails.js"></script>
<script src="/js/documents.js"></script>
<script src="/js/assessment.js"></script>
<script src="/js/main.js"></script>
<script src="/js/modal_stack.js"></script>
{{> dashboard_scripts}}
    {{> global_toasts}}
    <script src="/js/utils.js"></script>
</body>
</html>
