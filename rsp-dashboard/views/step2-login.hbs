{{> header}}

<div class="d-flex justify-content-center align-items-center" style="min-height: calc(100vh - 2rem);">
    <div class="glass-panel p-5 shadow-lg rounded-4 d-print-none" style="width: 100%; max-width: 450px;">
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center bg-primary text-white rounded-circle mb-3 shadow" style="width: 64px; height: 64px;">
                <i class="bi bi-shield-lock-fill fs-2"></i>
            </div>
            <h3 class="fw-bold text-dark mb-1">Step 2 Authentication</h3>
            <p class="text-muted small">Please login to access the Deliberation interface.</p>
        </div>

        {{#if error}}
        <div class="alert alert-danger d-flex align-items-center rounded-3 border-0 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2"></i>
            <div>{{error}}</div>
        </div>
        {{/if}}

        <form action="/step2-login" method="POST">
            <div class="mb-3">
                <label for="username" class="form-label fw-semibold text-dark">Username</label>
                <div class="input-group glass-panel">
                    <span class="input-group-text"><i class="bi bi-person-fill text-primary"></i></span>
                    <input type="text" class="form-control" id="username" name="username" placeholder="Enter your username" required autofocus>
                </div>
            </div>
            <div class="mb-4">
                <label for="password" class="form-label fw-semibold text-dark">Password</label>
                <div class="input-group glass-panel">
                    <span class="input-group-text"><i class="bi bi-key-fill text-primary"></i></span>
                    <input type="password" class="form-control" id="password" name="password" placeholder="Enter your password" required>
                </div>
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold rounded-pill shadow btn-add-glass">
                <i class="bi bi-box-arrow-in-right me-1"></i> Authenticate
            </button>
            <div class="text-center mt-4">
                <a href="/dashboard" class="text-decoration-none text-muted small cursor-pointer">
                    <i class="bi bi-arrow-left"></i> Return to Dashboard
                </a>
            </div>
        </form>
    </div>
</div>

        </div> <!-- End container-fluid -->
    </main>
</div> <!-- End d-flex wrapper -->

<script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
<script src="/js/utils.js?v=2.0"></script>
</body>
</html>
