{{> header}}

<div class="glass-panel p-4 mb-0 shadow-sm rounded-4 d-print-none">
    <!-- Tab Content -->
    
        <!-- STEP 1 -->
        {{#if step1Active}}
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="fw-semibold">Initial Evaluation</h2>
            </div>
            <p class="text-muted">Review incoming applicants and verify personal data sheet, birth certificate, and transcript of records.</p>
            
            <div class="mb-3">
                <form method="GET" action="/step1/1" class="row g-2">
                    <div class="col-md-6">
                        <div class="input-group glass-panel h-100">
                            <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                            <input type="text" name="q" class="form-control bg-transparent border-0 shadow-none" placeholder="Search by name or tracking number..." value="{{searchQuery}}">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="glass-panel h-100 px-2 py-1">
                            <select name="position" class="form-select bg-transparent border-0 shadow-none" onchange="this.form.submit()">
                                <option value="">All Positions (Filter by Salary Grade/Position)</option>
                                {{#each positionList}}
                                    <option value="{{this}}" {{#if (eq this ../positionFilter)}}selected{{/if}}>{{this}}</option>
                                {{/each}}
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <a href="/api/export/ier{{#if positionFilter}}?position={{positionFilter}}{{/if}}" class="btn btn-outline-success w-100 h-100 d-flex align-items-center justify-content-center fw-semibold">
                            <i class="bi bi-file-earmark-spreadsheet me-2"></i> Download IER
                        </a>
                    </div>
                </form>
            </div>

            <div class="rounded-3 overflow-hidden shadow-sm">
                <table class="table table-hover align-middle mb-0 custom-table" id="table-step1">
                    <thead class="table-light">
                        <tr>
                            <th>Application Code</th>
                            <th>Applicant Name</th>
                            <th class="text-center">Info</th>
                            <th class="text-center">Edu</th>
                            <th class="text-center">Train</th>
                            <th class="text-center">Exp</th>
                            <th class="text-center">Elig</th>
                            <th>Remarks</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each step1}}
                        <tr>
                            <td><span class="badge bg-secondary font-monospace">{{this.applicationCode}}</span></td>
                            <td class="fw-medium applicant-name-display-{{this.id}}">{{this.name}}</td>
                            <td class="text-center"><button class="btn btn-sm btn-outline-primary" onclick="openInfoModal({{this.id}})" title="Personal Info"><i class="bi bi-person-lines-fill"></i></button></td>
                            <td class="text-center"><button class="btn btn-sm btn-outline-info" onclick="openEduModal({{this.id}})" title="Education"><i class="bi bi-mortarboard-fill"></i></button></td>
                            <td class="text-center"><button class="btn btn-sm btn-outline-warning" onclick="openTrainModal({{this.id}})" title="Training"><i class="bi bi-award-fill"></i></button></td>
                            <td class="text-center"><button class="btn btn-sm btn-outline-success" onclick="openExpModal({{this.id}})" title="Experience"><i class="bi bi-briefcase-fill"></i></button></td>
                            <td class="text-center"><button class="btn btn-sm btn-outline-secondary" onclick="openEligModal({{this.id}})" title="Eligibility"><i class="bi bi-shield-check"></i></button></td>
                            <td id="remarks-cell-{{this.id}}">
                                {{#if (eq this.docRemark 'Qualified')}}
                                    <span class="badge bg-success">Qualified</span>
                                {{else if (eq this.docRemark 'Disqualified')}}
                                    <span class="badge bg-danger">Disqualified</span>
                                {{else if (eq this.docRemark 'Assessed')}}
                                    <span class="badge bg-success text-white">Assessed</span>
                                {{else if (eq this.docRemark 'In-Prog')}}
                                    <span class="badge bg-info text-dark">In-Prog</span>
                                {{else}}
                                    <span class="badge bg-warning text-dark">Pending</span>
                                {{/if}}
                            </td>
                            <td class="text-end">
                                {{#if (eq this.status 'PENDING')}}
                                <button class="btn btn-sm btn-primary action-btn" data-name="{{this.name}}" onclick="openSummaryModal({{this.id}}, this.getAttribute('data-name'))"><i class="bi bi-arrow-right-circle"></i> Move to Step 2</button>
                                {{/if}}
                                <button class="btn btn-sm btn-danger action-btn ms-1" onclick="deleteApplicant({{this.id}})"><i class="bi bi-trash"></i> Delete</button>
                            </td>
                        </tr>
                        {{else}}
                        <tr><td colspan="9" class="text-center text-muted py-4">No initial evaluation applicants found.</td></tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            
            {{#if pagination.[1]}}
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination flex-wrap justify-content-center mb-0">
                    {{#each pagination}}
                        {{#if this.isEllipsis}}
                            <li class="page-item disabled"><span class="page-link border-0 bg-transparent text-muted">...</span></li>
                        {{else}}
                            <li class="page-item {{#if this.isCurrent}}active{{/if}}">
                                <a class="page-link mx-1 {{#if this.isCurrent}}shadow-sm{{/if}} {{#if @first}}page-first{{else if @last}}page-last{{else}}rounded-circle{{/if}}" href="{{this.url}}">{{this.page}}</a>
                            </li>
                        {{/if}}
                    {{/each}}
                </ul>
            </nav>
            {{/if}}
        {{/if}}

        <!-- STEP 2 -->
        {{#if step2Active}}
            <h2 class="fw-semibold mb-3">Deliberation & Interview Sheet</h2>
            <p class="text-muted">Assess qualified applicants and input their interview scores (out of 100).</p>
            
            <div class="mb-3">
                
                <form method="GET" action="/step2/1" class="row g-2">
                    <div class="col-md-6">
                        <div class="input-group glass-panel h-100">
                            <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                            <input type="text" name="q" class="form-control bg-transparent border-0 shadow-none" placeholder="Search by name or tracking number..." value="{{searchQuery}}">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="glass-panel h-100 px-2 py-1">
                            <select name="position" class="form-select bg-transparent border-0 shadow-none" onchange="this.form.submit()">
                                <option value="">All Positions (Filter by Salary Grade/Position)</option>
                                {{#each positionList}}
                                    <option value="{{this}}" {{#if (eq this ../positionFilter)}}selected{{/if}}>{{this}}</option>
                                {{/each}}
                            </select>
                        </div>
                    </div>
                </form>
            </div>

            <div class="rounded-3 overflow-hidden shadow-sm">
                <table class="table table-hover align-middle mb-0 custom-table" id="table-step2">
                    <thead class="table-light">
                        <tr>
                            <th>Application Code</th>
                            <th>Applicant Name</th>
                            <th class="text-center">Evaluation Assessment</th>
                            <th class="text-center">Total</th>
                            <th>Remarks</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each step2}}
                        <tr>
                            <td><span class="badge bg-secondary font-monospace">{{this.applicationCode}}</span></td>
                            <td class="fw-medium applicant-name-display-{{this.id}}">{{this.name}}</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-info action-btn text-white fw-bold shadow-sm" onclick="openAssessmentModal({{this.id}}, '{{this.name}}')">
                                    <i class="bi bi-pencil-square"></i> Assess
                                </button>
                            </td>
                            <td class="text-center fw-bold text-primary fs-5">
                                {{#unless (eq this.scores.total null)}}
                                    {{this.scores.total}}
                                {{else}}
                                    -
                                {{/unless}}
                            </td>
                            <td>
                                {{#if (eq this.assessmentRemarks 'Assessed')}}<span class="badge bg-success">Assessed</span>
                                {{else if (eq this.assessmentRemarks 'In-Prog')}}<span class="badge bg-warning text-dark">In-Prog</span>
                                {{else}}<span class="badge bg-secondary">Pending</span>{{/if}}
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-primary action-btn" onclick="openStep2SummaryModal({{this.id}}, '{{this.name}}')" {{#unless (eq this.assessmentRemarks 'Assessed')}}disabled title="Must be fully Assessed"{{/unless}}>
                                    <i class="bi bi-arrow-right-circle"></i> Move to Step 3
                                </button>
                                <button class="btn btn-sm btn-danger action-btn ms-1" onclick="deleteApplicant({{this.id}})"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                        {{else}}
                        <tr><td colspan="6" class="text-center text-muted py-4">No applicants await interviews.</td></tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            
            {{#if pagination.[1]}}
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination flex-wrap justify-content-center mb-0">
                    {{#each pagination}}
                        {{#if this.isEllipsis}}
                            <li class="page-item disabled"><span class="page-link border-0 bg-transparent text-muted">...</span></li>
                        {{else}}
                            <li class="page-item {{#if this.isCurrent}}active{{/if}}">
                                <a class="page-link mx-1 {{#if this.isCurrent}}shadow-sm{{/if}} {{#if @first}}page-first{{else if @last}}page-last{{else}}rounded-circle{{/if}}" href="{{this.url}}">{{this.page}}</a>
                            </li>
                        {{/if}}
                    {{/each}}
                </ul>
            </nav>
            {{/if}}
        {{/if}}

        <!-- STEP 3 -->
        {{#if step3Active}}
            <h2 class="fw-semibold mb-3">Comparative Assessments</h2>
            <p class="text-muted">Leaderboard of assessed applicants ranked by their interview scores.</p>
            
            <div class="mb-3">
                
                <form method="GET" action="/step3/1" class="row g-2">
                    <div class="col-md-6">
                        <div class="input-group glass-panel h-100">
                            <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                            <input type="text" name="q" class="form-control bg-transparent border-0 shadow-none" placeholder="Search by name or tracking number..." value="{{searchQuery}}">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="glass-panel h-100 px-2 py-1">
                            <select name="position" class="form-select bg-transparent border-0 shadow-none" onchange="this.form.submit()">
                                <option value="">All Positions (Filter by Salary Grade/Position)</option>
                                {{#each positionList}}
                                    <option value="{{this}}" {{#if (eq this ../positionFilter)}}selected{{/if}}>{{this}}</option>
                                {{/each}}
                            </select>
                        </div>
                    </div>
                </form>
            </div>

            <div class="rounded-3 overflow-hidden shadow-sm">
                <table class="table table-hover align-middle mb-0 custom-table leaderboard" id="table-step3">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center" style="width: 80px;">Rank</th>
                            <th>Application Code</th>
                            <th>Applicant Name</th>
                            <th class="text-center">Score Summary</th>
                            <th class="text-center">Total</th>
                            <th class="text-center">Status</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each step3}}
                        <tr>
                            <td class="fw-bold text-primary text-center">#{{incOffset @index ../offset}}</td>
                            <td><span class="badge bg-secondary font-monospace">{{this.applicationCode}}</span></td>
                            <td class="fw-medium applicant-name-display-{{this.id}}">{{this.name}}</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-primary action-btn" onclick="openStep2SummaryModal({{this.id}}, '{{this.name}}', true)">
                                    <i class="bi bi-eye"></i> View Summary
                                </button>
                            </td>
                            <td class="text-center fw-bold text-success fs-5">
                                {{#unless (eq this.scores.total null)}}
                                    {{this.scores.total}}
                                {{else}}
                                    -
                                {{/unless}}
                            </td>
                            <td class="text-center"><span class="badge bg-success">Assessed</span></td>
                            <td class="text-end">
                                {{#if (eq this.status 'ASSESSED')}}
                                <button class="btn btn-sm btn-primary action-btn" onclick="proceedToRequirements({{this.id}}, '{{this.name}}')"><i class="bi bi-arrow-right-circle"></i> Move to Step 4</button>
                                {{/if}}
                                <button class="btn btn-sm btn-danger action-btn ms-1" onclick="deleteApplicant({{this.id}})"><i class="bi bi-trash"></i> Delete</button>
                            </td>
                        </tr>
                        {{else}}
                        <tr><td colspan="6" class="text-center text-muted py-4">No comparative data available yet.</td></tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            
            {{#if pagination.[1]}}
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination flex-wrap justify-content-center mb-0">
                    {{#each pagination}}
                        {{#if this.isEllipsis}}
                            <li class="page-item disabled"><span class="page-link border-0 bg-transparent text-muted">...</span></li>
                        {{else}}
                            <li class="page-item {{#if this.isCurrent}}active{{/if}}">
                                <a class="page-link mx-1 {{#if this.isCurrent}}shadow-sm{{/if}} {{#if @first}}page-first{{else if @last}}page-last{{else}}rounded-circle{{/if}}" href="{{this.url}}">{{this.page}}</a>
                            </li>
                        {{/if}}
                    {{/each}}
                </ul>
            </nav>
            {{/if}}
        {{/if}}

        <!-- STEP 4 -->
        {{#if step4Active}}
            <h4 class="fw-semibold mb-3">Notice of Requirements</h4>
            <p class="text-muted">Finalized applicants ready for assignment. Generate assignment letters here.</p>
            
            <div class="mb-3">
                
                <form method="GET" action="/step4/1" class="row g-2">
                    <div class="col-md-6">
                        <div class="input-group glass-panel h-100">
                            <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                            <input type="text" name="q" class="form-control bg-transparent border-0 shadow-none" placeholder="Search by name or tracking number..." value="{{searchQuery}}">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="glass-panel h-100 px-2 py-1">
                            <select name="position" class="form-select bg-transparent border-0 shadow-none" onchange="this.form.submit()">
                                <option value="">All Positions (Filter by Salary Grade/Position)</option>
                                {{#each positionList}}
                                    <option value="{{this}}" {{#if (eq this ../positionFilter)}}selected{{/if}}>{{this}}</option>
                                {{/each}}
                            </select>
                        </div>
                    </div>
                </form>
            </div>

            <div class="rounded-3 overflow-hidden shadow-sm">
                <table class="table table-hover align-middle mb-0 custom-table" id="table-step4">
                    <thead class="table-light">
                        <tr>
                            <th>Application Code</th>
                            <th>Applicant Name</th>
                            <th class="text-center">Score</th>
                            <th class="text-center">Requirements</th>
                            <th class="text-center">Remarks</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each step4}}
                        <tr id="applicant-row-{{this.id}}">
                            <td><span class="badge bg-secondary font-monospace">{{this.applicationCode}}</span></td>
                            <td class="fw-medium applicant-name-display-{{this.id}}">{{this.name}}</td>
                            <td class="text-center fw-bold text-success fs-5">
                                {{#unless (eq this.scores.total null)}}
                                    {{this.scores.total}}
                                {{else}}
                                    -
                                {{/unless}}
                            </td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-primary action-btn" onclick="openRequirementsModal({{this.id}}, '{{this.name}}')">
                                    <i class="bi bi-list-check"></i> View Requirements
                                </button>
                            </td>
                            <td class="text-center">
                                <div class="mt-2">
                                    {{#if (allRequirementsMet this)}}
                                        <span id="requirements-status-{{this.id}}" class="badge bg-success">Complete</span>
                                    {{else}}
                                        <span id="requirements-status-{{this.id}}" class="badge bg-warning text-dark">Incomplete</span>
                                    {{/if}}
                                </div>
                            </td>
                            <td class="text-end">
                                <button id="assign-btn-{{this.id}}" class="btn btn-sm btn-primary action-btn" {{#if (eq this.assignmentReqStatus 'INCOMPLETE')}}disabled title="Requirements must be complete"{{/if}} onclick="openAssignModal({{this.id}}, '{{this.name}}')"><i class="bi bi-arrow-right-circle"></i> Move to Step 5</button>
                                <button class="btn btn-sm btn-danger action-btn ms-1" onclick="deleteApplicant({{this.id}})"><i class="bi bi-trash"></i> Delete</button>
                            </td>
                        </tr>
                        {{else}}
                        <tr><td colspan="6" class="text-center text-muted py-4">No applicants waiting for requirements.</td></tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            
            {{#if pagination.[1]}}
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination flex-wrap justify-content-center mb-0">
                    {{#each pagination}}
                        {{#if this.isEllipsis}}
                            <li class="page-item disabled"><span class="page-link border-0 bg-transparent text-muted">...</span></li>
                        {{else}}
                            <li class="page-item {{#if this.isCurrent}}active{{/if}}">
                                <a class="page-link mx-1 {{#if this.isCurrent}}shadow-sm{{/if}} {{#if @first}}page-first{{else if @last}}page-last{{else}}rounded-circle{{/if}}" href="{{this.url}}">{{this.page}}</a>
                            </li>
                        {{/if}}
                    {{/each}}
                </ul>
            </nav>
            {{/if}}
        {{/if}}

        <!-- STEP 5 -->
        {{#if step5Active}}
            <h4 class="fw-semibold mb-3">Assignment Orders</h4>
            <p class="text-muted">Finalized applicants ready for assignment. Generate assignment letters here.</p>
            
            <div class="mb-3">
                
                <form method="GET" action="/step5/1">
                    <div class="input-group glass-panel">
                        <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="q" class="form-control bg-transparent border-0 shadow-none" placeholder="Search by name or tracking number..." value="{{searchQuery}}">
                        <button type="submit" class="d-none"></button>
                    </div>
                </form>
            </div>

            <div class="rounded-3 overflow-hidden shadow-sm">
                <table class="table table-hover align-middle mb-0 custom-table" id="table-step5">
                    <thead class="table-light">
                        <tr>
                            <th>Application Code</th>
                            <th>Applicant Name</th>
                            <th>Assigned Office</th>
                            <th>Score</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each step5}}
                        <tr>
                            <td><span class="badge bg-secondary font-monospace">{{this.applicationCode}}</span></td>
                            <td class="fw-medium applicant-name-display-{{this.id}}">{{this.name}}</td>
                            <td>{{this.assignedOffice}}</td>
                            <td>{{this.interviewScore}}</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary action-btn" onclick="printLetter('{{this.name}}', '{{this.assignedOffice}}', '', '{{this.category}}')">
                                    <i class="bi bi-file-earmark-pdf"></i> Generate PDF
                                </button>
                                <button class="btn btn-sm btn-danger action-btn ms-1" onclick="deleteApplicant({{this.id}})"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                        {{else}}
                        <tr><td colspan="5" class="text-center text-muted py-4">No assignment orders available.</td></tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            
            {{#if pagination.[1]}}
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination flex-wrap justify-content-center mb-0">
                    {{#each pagination}}
                        {{#if this.isEllipsis}}
                            <li class="page-item disabled"><span class="page-link border-0 bg-transparent text-muted">...</span></li>
                        {{else}}
                            <li class="page-item {{#if this.isCurrent}}active{{/if}}">
                                <a class="page-link mx-1 {{#if this.isCurrent}}shadow-sm{{/if}} {{#if @first}}page-first{{else if @last}}page-last{{else}}rounded-circle{{/if}}" href="{{this.url}}">{{this.page}}</a>
                            </li>
                        {{/if}}
                    {{/each}}
                </ul>
            </nav>
            {{/if}}
        {{/if}}
    </div>
<!-- Modals (Hidden from print) -->
<div class="d-print-none">
    <!-- Add Applicant Modal -->
    <div class="modal fade glass-modal" id="addApplicantModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold" id="addApplicantModalTitle">New Applicant Wizard</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="addApplicantForm">
                        <!-- Step 0: Category & Position -->
                        <div id="wizardStep0">
                            <h6 class="mb-3 text-center fw-bold">Select Applicant Category</h6>
                            <div class="row g-3 mb-3" id="categorySelection">
                                <div class="col-12"><button type="button" class="btn btn-outline-primary w-100 py-3 fw-semibold" onclick="selectCategory('Related Teaching')">Related Teaching</button></div>
                                <div class="col-12"><button type="button" class="btn btn-outline-primary w-100 py-3 fw-semibold" onclick="selectCategory('School Administration')">School Administration</button></div>
                                <div class="col-12"><button type="button" class="btn btn-outline-primary w-100 py-3 fw-semibold" onclick="selectCategory('Non-Teaching')">Non-Teaching</button></div>
                            </div>
                            
                            <div id="positionSelection" class="d-none">
                                <div class="d-flex align-items-center mb-3">
                                    <button type="button" class="btn btn-sm btn-light me-2" onclick="backToCategories()"><i class="bi bi-arrow-left"></i></button>
                                    <h6 class="mb-0 fw-bold" id="selectedCategoryTitle">Select Position</h6>
                                </div>
                                <div class="list-group" id="positionList">
                                    <!-- Populated via JS -->
                                </div>
                            </div>
                        </div>

                        <!-- Step 1: Personal Info -->
                        <div id="wizardStep1" class="d-none">
                            <div class="d-flex align-items-center mb-3">
                                <button type="button" class="btn btn-sm btn-light me-2" onclick="backToPositions()"><i class="bi bi-arrow-left"></i></button>
                                <h6 class="mb-0 fw-bold text-primary">Personal Information</h6>
                            </div>
                            <input type="hidden" name="category" id="wizardCategory">
                            <input type="hidden" name="position" id="wizardPosition">
                            <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">First Name</label>
                                <input type="text" class="form-control" name="firstName" required placeholder="e.g. John">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Last Name</label>
                                <input type="text" class="form-control" name="lastName" required placeholder="e.g. Doe">
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Address</label>
                                <input type="text" class="form-control" name="address">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Age</label>
