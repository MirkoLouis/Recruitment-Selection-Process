                            <div class="form-text mt-0">Score = (x / 100) * 10</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold small">c. Behavioural Events Interview (BEI) - Max 5 pts</label>
                            <input type="number" class="form-control form-control-sm mb-1" id="potBEIInput" step="0.01" max="5" placeholder="Raw BEI points (0-5)" oninput="calculatePotentialPoints()">
                            <div class="form-text mt-0">Enter cumulative raw points given.</div>
                        </div>
                    </div>

                    <hr class="my-4 border-secondary border-opacity-25">

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="text-muted fw-bold">Total Potential Points:</span>
                        <span class="fs-4 fw-bold text-success" id="calculatedPotentialPoints">0</span>
                    </div>
                    
                    <button type="button" class="btn btn-success text-white w-100 fw-bold shadow-sm" onclick="applyPotentialPoints()">
                        <i class="bi bi-check-circle"></i> Apply Points
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Step 2 Summary & Move to Step 3 Modal -->
    <div class="modal fade glass-modal" id="step2SummaryModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-bottom border-light border-opacity-25 bg-primary bg-opacity-10 text-primary">
                    <h5 class="modal-title fw-bold"><i class="bi bi-file-earmark-bar-graph"></i> Pre-Interview Summary</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="step2SummaryForm">
                        <input type="hidden" id="step2SummaryApplicantId">
                        <h5 id="step2SummaryApplicantName" class="text-center text-primary fw-bold mb-4"></h5>
                        
                        <div id="step2SummaryDetails" class="mb-4">
                            <!-- Populated via JS -->
                        </div>
                        
                        <hr class="my-4 border-secondary border-opacity-25">
                        
                        <div class="mt-4" id="step2SummarySubmitBtnDiv">
                            <button type="submit" class="btn btn-primary text-white w-100 btn-lg shadow-sm fw-bold">
                                <i class="bi bi-check-circle me-1"></i> Confirm & Move to Step 3
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Step 3 Move to Step 4 Confirmation Modal -->
    <div class="modal fade glass-modal" id="step3ConfirmModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-bottom border-light border-opacity-25 bg-warning bg-opacity-10 text-warning">
                    <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle"></i> Confirm Action</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 text-center">
                    <input type="hidden" id="step3ConfirmApplicantId">
                    <h5 class="mb-4">Are you sure you want to move <br><span id="step3ConfirmApplicantName" class="text-primary fw-bold fs-4"></span><br> to Step 4?</h5>
                    <p class="text-muted mb-4">This will send them to the Notice of Requirements stage.</p>
                    <div class="d-flex justify-content-center gap-3">
                        <button type="button" class="btn btn-secondary px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary px-4 fw-bold shadow-sm" onclick="confirmProceedToStep4()">
                            <i class="bi bi-check-circle me-1"></i> Proceed to Step 4
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap Bundle with Popper -->
    <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/js/applicantWizard.js"></script>
    <script src="/js/pdfGenerator.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <!-- Custom JS -->
    <script src="/js/main.js"></script>
</body>
</html>