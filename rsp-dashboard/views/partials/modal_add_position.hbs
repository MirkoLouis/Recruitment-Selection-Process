<!-- Add Position Modal -->
<div class="modal fade glass-modal" id="addPositionModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 bg-primary bg-opacity-10 text-primary pb-3">
                <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle-fill me-2"></i>Add New Position</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="addPositionForm">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="newPositionTitle" class="form-label">Position Title</label>
                            <input type="text" class="form-control" id="newPositionTitle" name="title" required placeholder="e.g. Teacher I">
                        </div>
                        <div class="col-md-6">
                            <label for="newPositionCategory" class="form-label">Category</label>
                            <select class="form-select searchable-select" id="newPositionCategory" name="category" required>
                                <option value="">Select a Category...</option>
                                {{#each groupedPositions}}
                                    <option value="{{this.categoryName}}">{{this.categoryName}}</option>
                                {{/each}}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="newPositionSalary" class="form-label">Salary Grade</label>
                            <input type="number" class="form-control" id="newPositionSalary" name="salaryGrade" placeholder="e.g. 11">
                        </div>
                        <div class="col-md-6">
                            <label for="newPositionMonthly" class="form-label">Monthly Salary</label>
                            <input type="number" step="0.01" class="form-control" id="newPositionMonthly" name="monthlySalary" placeholder="e.g. 27000">
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-light shadow-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary shadow-sm" onclick="submitNewPosition()">
                    <i class="bi bi-save"></i> Save Position
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function submitNewPosition() {
        // Implement save logic here
        alert("Save position functionality will be implemented here.");
        const modal = bootstrap.Modal.getInstance(document.getElementById('addPositionModal'));
        if (modal) modal.hide();
    }
</script>
