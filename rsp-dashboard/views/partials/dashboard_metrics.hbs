        <!-- Metrics Tab -->
        <div class="tab-pane fade {{#unless selectedPosition}}{{#unless showMasterlist}}{{#unless showCategories}}show active{{/unless}}{{/unless}}{{/unless}}" id="metrics" role="tabpanel">
            <div id="metricsDashboardGrid">
                <div class="row g-4 mb-4">
                    <div class="col-md-12">
                        <div class="card border-0 glass-panel shadow-sm rounded-4 h-100" style="background: linear-gradient(135deg, rgba(13,110,253,0.1) 0%, rgba(13,110,253,0.05) 100%); border-left: 5px solid #0d6efd !important;">
                            <div class="card-body p-4 d-flex flex-wrap align-items-center justify-content-between">
                                <div class="d-flex align-items-center mb-3 mb-md-0">
                                    <div class="display-4 text-primary fw-bold me-4"><i class="bi bi-briefcase-fill"></i></div>
                                    <div>
                                        <h3 class="fw-bold mb-1" id="metricsTotalVacant">{{totalVacantCount}}</h3>
                                        <p class="text-muted mb-0">Total Vacant Positions Across All Categories</p>
                                    </div>
                                </div>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-outline-primary rounded-pill px-4 shadow-sm" onclick="window.location.href='/api/positions/export/doc'">
                                        <i class="bi bi-file-earmark-word-fill me-2"></i>Doc
                                    </button>
                                    <button class="btn btn-primary rounded-pill px-4 shadow-sm" onclick="alert('Excel download feature coming soon!')">
                                        <i class="bi bi-file-earmark-excel-fill me-2"></i>Excel
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <h5 class="fw-bold mb-3 text-muted"><i class="bi bi-bar-chart-fill me-2"></i>Vacancies per Category</h5>
                <div class="row g-4">
                    {{#each groupedPositions}}
                    <div class="col-md-6 col-lg-6">
                        <div class="card border-0 glass-panel shadow-sm rounded-4 h-100 p-2 category-metric-card {{#if this.hasVacancy}}border-start border-4 border-success{{else}}border-start border-4 border-secondary opacity-75{{/if}}" 
                            data-category-card="{{this.categoryName}}" 
                            style="transition: transform 0.2s; cursor: pointer;" 
                            onmouseover="this.style.transform='translateY(-5px)'" 
                            onmouseout="this.style.transform='translateY(0)'"
                            onclick="showCategoryChart('{{this.categoryName}}')">
                            <div class="card-body p-2">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h6 class="fw-bold mb-0 text-truncate" title="{{this.categoryName}}">{{this.categoryName}}</h6>
                                    <span class="badge {{#if this.hasVacancy}}bg-success{{else}}bg-secondary{{/if}} rounded-pill" data-category-badge="{{this.categoryName}}" style="font-size: 0.7rem;">
                                        {{#if this.hasVacancy}}Active{{else}}No Vacancy{{/if}}
                                    </span>
                                </div>
                                <div class="mt-4 d-flex align-items-end justify-content-between">
                                    <div>
                                        <h2 class="fw-bold mb-0 {{#if this.hasVacancy}}text-success{{else}}text-muted{{/if}}" data-category-count="{{this.categoryName}}">{{this.vacantCount}}</h2>
                                        <small class="text-muted">Vacant</small>
                                    </div>
                                    <i class="bi bi-pie-chart-fill fs-2 text-muted opacity-25"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                    {{/each}}
                </div>
            </div>

            <!-- Detailed Chart View (Hidden by Default) -->
            <div id="metricsChartContainer" class="d-none">
                <div class="d-flex align-items-center mb-4">
                    <button type="button" class="btn btn-light shadow-sm me-3 rounded-circle" onclick="hideCategoryChart()" style="width: 45px; height: 45px;">
                        <i class="bi bi-arrow-left fs-5"></i>
                    </button>
                    <div>
                        <h4 class="mb-0 fw-bold text-primary" id="metricsChartTitle">Category Name</h4>
                        <p class="text-muted mb-0 small">Vacancies per position</p>
                    </div>
                </div>
                <div class="glass-panel p-4 rounded-4 shadow-sm bg-white" style="min-height: 400px;">
                    <div id="chartFlexContainer" class="d-flex flex-wrap justify-content-center align-items-center w-100">
                        <div style="width: 350px; height: 350px; flex-shrink: 0;">
                            <canvas id="categoryPieChart"></canvas>
                        </div>
                        <div id="customChartLegend" class="ms-md-4 mt-4 mt-md-0 flex-grow-1" style="max-height: 350px; overflow-y: auto; min-width: 300px; padding-right: 10px;">
                            <!-- Legend items will be injected here -->
                        </div>
                    </div>
                    <div id="noVacancyMessage" class="d-none text-center text-muted w-100 py-5">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        <h5>No Vacant Positions</h5>
                        <p>There are currently no active vacancies set for this category.</p>
                    </div>
                </div>
            </div>
        </div>