        <!-- STEP 1 -->
        {{#if step1Active}}
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="fw-semibold mb-0">Initial Evaluation</h2>
            </div>
            <p class="text-muted">Conduct initial evaluation of incoming applicants by verifying the completeness of their mandatory documentary requirements.</p>
            
            <div class="mb-3">
                <form method="GET" action="/step1/1" class="row g-2">
                    <div class="col-md-3">
                        <div class="input-group glass-panel h-100 shadow-sm">
                            <span class="input-group-text bg-white border-end-0 cursor-pointer" onclick="this.closest('form').submit()"><i class="bi bi-search text-primary"></i></span>
                            <input type="text" name="q" class="form-control border-start-0 ps-0" placeholder="Search by name or application code..." value="{{searchQuery}}">
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="glass-panel filter-glass-panel h-100 px-2 py-1">
                            <select name="position" class="form-select bg-transparent border-0 shadow-none custom-ui-select" onchange="if(this.form.vacancy) this.form.vacancy.value=''; if(this.form.step) this.form.step.value=''; if(this.form.remarks) this.form.remarks.value=''; if(this.form.office) this.form.office.value=''; this.form.submit()">
                                <option value="">All Positions</option>
                                {{#each positionList}}
                                    <option value="{{this}}" {{#if (eq this ../positionFilter)}}selected{{/if}}>{{this}}</option>
                                {{/each}}
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="glass-panel filter-glass-panel h-100 px-2 py-1">
                            <select name="vacancy" class="form-select bg-transparent border-0 shadow-none custom-ui-select" onchange="this.form.submit()">
                                <option value="">All Vacancies</option>
                                {{#each vacancyList}}
                                    <option value="{{this}}" {{#if (eq this ../vacancyFilter)}}selected{{/if}}>{{this}}</option>
                                {{/each}}
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="glass-panel filter-glass-panel h-100 px-2 py-1">
                            <select name="remarks" class="form-select bg-transparent border-0 shadow-none custom-ui-select" onchange="this.form.submit()">
                                <option value="">All Steps & Remarks</option>
                                {{#each remarksList}}
                                    <option value="{{this.value}}" {{#if (eq this.value ../remarksFilter)}}selected{{/if}}>{{this.label}}</option>
                                {{/each}}
                            </select>
                        </div>
                    </div>
                    <div class="col-md-auto ms-auto">
                        <button type="button" class="btn btn-outline-success h-100 px-3 d-flex align-items-center justify-content-center fw-semibold" onclick="handleIERDownloadClick()">
                            <i class="bi bi-file-earmark-spreadsheet me-2"></i> Download IER
                        </button>
                    </div>
                </form>
            </div>

            <div class="rounded-3 shadow-sm table-responsive-wrapper bg-white">
                <table class="table table-hover align-middle mb-0 custom-table" id="table-step1">
                    <thead class="table-light">
                        <tr>
                            <th>Application Code</th>
                            <th>Applicant Name</th>
                            <th class="text-center">Info</th>
                            <th class="text-center">Edu</th>
                            <th class="text-center">Train</th>
                            <th class="text-center">Exp</th>
                            <th class="text-center">Elig</th>
                            <th>Remarks</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each step1}}
                        <tr>
                            <td><span class="badge bg-secondary font-monospace">{{this.applicationCode}}</span></td>
                            <td class="fw-medium applicant-name-display-{{this.id}}">{{titleCase this.name}}</td>
                            <td class="text-center"><button class="btn btn-sm btn-outline-primary shadow-sm d-inline-flex align-items-center text-nowrap gap-1" onclick="openInfoModal({{this.id}})" title="Personal Info"><i class="bi bi-person-badge"></i> Info</button></td>
                            <td class="text-center"><button class="btn btn-sm btn-outline-info shadow-sm d-inline-flex align-items-center text-nowrap gap-1" onclick="openEduModal({{this.id}})" title="Education"><i class="bi bi-mortarboard-fill"></i> Education</button></td>
                            <td class="text-center"><button class="btn btn-sm btn-outline-warning shadow-sm d-inline-flex align-items-center text-nowrap gap-1" onclick="openTrainModal({{this.id}})" title="Training"><i class="bi bi-award-fill"></i> Training</button></td>
                            <td class="text-center"><button class="btn btn-sm btn-outline-success shadow-sm d-inline-flex align-items-center text-nowrap gap-1" onclick="openExpModal({{this.id}})" title="Experience"><i class="bi bi-briefcase-fill"></i> Experience</button></td>
                            <td class="text-center"><button class="btn btn-sm btn-outline-secondary shadow-sm d-inline-flex align-items-center text-nowrap gap-1" onclick="openEligModal({{this.id}})" title="Eligibility"><i class="bi bi-shield-check"></i> Eligibility</button></td>
                            <td id="remarks-cell-{{this.id}}">
                                {{#if (eq this.docRemark 'Qualified')}}
                                    <span class="badge bg-success">Qualified</span>
                                {{else if (eq this.docRemark 'Disqualified')}}
                                    <span class="badge bg-danger">Disqualified</span>
                                {{else if (eq this.docRemark 'Assessed')}}
                                    <span class="badge bg-success text-white">Assessed</span>
                                {{else if (eq this.docRemark 'In-Prog')}}
                                    <span class="badge bg-info text-dark">In-Prog</span>
                                {{else}}
                                    <span class="badge bg-warning text-dark">Pending</span>
                                {{/if}}
                            </td>
                            <td class="text-end">
                                {{#if (eq this.status 'PENDING')}}
                                <button class="btn btn-sm btn-primary action-btn" data-name="{{titleCase this.name}}" onclick="openSummaryModal({{this.id}}, this.getAttribute('data-name'))" title="Evaluate Applicant"><i class="bi bi-card-checklist"></i> Evaluate</button>
                                {{/if}}
                                {{#if (eq this.status 'QUALIFIED')}}
                                <button class="btn btn-sm btn-success action-btn" onclick="openProceedModal({{this.id}}, '{{titleCase this.name}}')" title="Proceed to Step 2"><i class="bi bi-arrow-right-circle"></i> Proceed</button>
                                {{/if}}
                                {{#if (eq this.docRemark 'Pending')}}
                                <button class="btn btn-sm btn-secondary action-btn ms-1" disabled title="Requires Assessed remarks"><i class="bi bi-file-earmark-word"></i> DOC</button>
                                {{else if (eq this.docRemark 'In-Prog')}}
                                <button class="btn btn-sm btn-secondary action-btn ms-1" disabled title="Requires Assessed remarks"><i class="bi bi-file-earmark-word"></i> DOC</button>
                                {{else}}
                                <button class="btn btn-sm btn-outline-primary action-btn ms-1" onclick="window.openGenericDocModal(1, {{this.id}}, '{{this.status}}', '{{this.docRemark}}', `{{titleCase this.name}}`, '', '', `{{this.applicationCode}}`, '', '')" title="Generate DOC (Eval)"><i class="bi bi-file-earmark-word"></i> DOC</button>
                                {{/if}}
                            </td>
                        </tr>
                        {{else}}
                        <tr><td colspan="9" class="text-center text-muted py-4">No initial evaluation applicants found.</td></tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            
            {{#if pagination.[1]}}
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination flex-wrap justify-content-center mb-0">
                    {{#each pagination}}
                        {{#if this.isEllipsis}}
                            <li class="page-item disabled"><span class="page-link border-0 bg-transparent text-muted">...</span></li>
                        {{else}}
                            <li class="page-item {{#if this.isCurrent}}active{{/if}}">
                                <a class="page-link mx-1 {{#if this.isCurrent}}shadow-sm{{/if}} {{#if @first}}page-first{{else if @last}}page-last{{else}}rounded-circle{{/if}}" href="{{this.url}}">{{this.page}}</a>
                            </li>
                        {{/if}}
                    {{/each}}
                </ul>
            </nav>
            {{/if}}
        {{/if}}



