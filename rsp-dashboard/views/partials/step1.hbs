        <!-- STEP 1 -->
        {{#if step1Active}}
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="fw-semibold">Initial Evaluation</h2>
            </div>
            <p class="text-muted">Review incoming applicants and verify personal data sheet, birth certificate, and transcript of records.</p>
            
            <div class="mb-3">
                <form method="GET" action="/step1/1" class="row g-2">
                    <div class="col-md-6">
                        <div class="input-group glass-panel h-100">
                            <span class="input-group-text bg-white border-end-0 cursor-pointer" onclick="this.closest('form').submit()"><i class="bi bi-search text-primary"></i></span>
                            <input type="text" name="q" class="form-control bg-transparent border-0 shadow-none" placeholder="Search by name or tracking number..." value="{{searchQuery}}">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="glass-panel h-100 px-2 py-1">
                            <select name="position" class="form-select bg-transparent border-0 shadow-none" onchange="this.form.submit()">
                                <option value="">All Positions (Filter by Salary Grade/Position)</option>
                                {{#each positionList}}
                                    <option value="{{this}}" {{#if (eq this ../positionFilter)}}selected{{/if}}>{{this}}</option>
                                {{/each}}
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <a href="/api/export/ier{{#if positionFilter}}?position={{positionFilter}}{{/if}}" class="btn btn-outline-success w-100 h-100 d-flex align-items-center justify-content-center fw-semibold">
                            <i class="bi bi-file-earmark-spreadsheet me-2"></i> Download IER
                        </a>
                    </div>
                </form>
            </div>

            <div class="rounded-3 shadow-sm table-responsive-wrapper bg-white">
                <table class="table table-hover align-middle mb-0 custom-table" id="table-step1">
                    <thead class="table-light">
                        <tr>
                            <th>Application Code</th>
                            <th>Applicant Name</th>
                            <th class="text-center">Info</th>
                            <th class="text-center">Edu</th>
                            <th class="text-center">Train</th>
                            <th class="text-center">Exp</th>
                            <th class="text-center">Elig</th>
                            <th>Remarks</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each step1}}
                        <tr>
                            <td><span class="badge bg-secondary font-monospace">{{this.applicationCode}}</span></td>
                            <td class="fw-medium applicant-name-display-{{this.id}}">{{this.name}}</td>
                            <td class="text-center"><button class="btn btn-sm btn-outline-primary shadow-sm d-inline-flex align-items-center text-nowrap gap-1" onclick="openInfoModal({{this.id}})" title="Personal Info"><i class="bi bi-person-badge"></i> Info</button></td>
                            <td class="text-center"><button class="btn btn-sm btn-outline-info shadow-sm d-inline-flex align-items-center text-nowrap gap-1" onclick="openEduModal({{this.id}})" title="Education"><i class="bi bi-mortarboard-fill"></i> Education</button></td>
                            <td class="text-center"><button class="btn btn-sm btn-outline-warning shadow-sm d-inline-flex align-items-center text-nowrap gap-1" onclick="openTrainModal({{this.id}})" title="Training"><i class="bi bi-award-fill"></i> Training</button></td>
                            <td class="text-center"><button class="btn btn-sm btn-outline-success shadow-sm d-inline-flex align-items-center text-nowrap gap-1" onclick="openExpModal({{this.id}})" title="Experience"><i class="bi bi-briefcase-fill"></i> Experience</button></td>
                            <td class="text-center"><button class="btn btn-sm btn-outline-secondary shadow-sm d-inline-flex align-items-center text-nowrap gap-1" onclick="openEligModal({{this.id}})" title="Eligibility"><i class="bi bi-shield-check"></i> Eligibility</button></td>
                            <td id="remarks-cell-{{this.id}}">
                                {{#if (eq this.docRemark 'Qualified')}}
                                    <span class="badge bg-success">Qualified</span>
                                {{else if (eq this.docRemark 'Disqualified')}}
                                    <span class="badge bg-danger">Disqualified</span>
                                {{else if (eq this.docRemark 'Assessed')}}
                                    <span class="badge bg-success text-white">Assessed</span>
                                {{else if (eq this.docRemark 'In-Prog')}}
                                    <span class="badge bg-info text-dark">In-Prog</span>
                                {{else}}
                                    <span class="badge bg-warning text-dark">Pending</span>
                                {{/if}}
                            </td>
                            <td class="text-end">
                                {{#if (eq this.status 'PENDING')}}
                                <button class="btn btn-sm btn-primary action-btn" data-name="{{this.name}}" onclick="openSummaryModal({{this.id}}, this.getAttribute('data-name'))" title="Move to Step 2"><i class="bi bi-arrow-right-circle"></i> Move</button>
                                {{/if}}
                                {{#if (eq this.docRemark 'Assessed')}}
                                <button class="btn btn-sm btn-danger action-btn ms-1" onclick="printInitialEvalPdf({{this.id}})" title="Generate PDF (Eval)"><i class="bi bi-file-earmark-pdf"></i> PDF</button>
                                {{else}}
                                <button class="btn btn-sm btn-secondary action-btn ms-1" disabled title="Requires Assessed remarks"><i class="bi bi-file-earmark-pdf"></i> PDF</button>
                                {{/if}}
                            </td>
                        </tr>
                        {{else}}
                        <tr><td colspan="9" class="text-center text-muted py-4">No initial evaluation applicants found.</td></tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            
            {{#if pagination.[1]}}
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination flex-wrap justify-content-center mb-0">
                    {{#each pagination}}
                        {{#if this.isEllipsis}}
                            <li class="page-item disabled"><span class="page-link border-0 bg-transparent text-muted">...</span></li>
                        {{else}}
                            <li class="page-item {{#if this.isCurrent}}active{{/if}}">
                                <a class="page-link mx-1 {{#if this.isCurrent}}shadow-sm{{/if}} {{#if @first}}page-first{{else if @last}}page-last{{else}}rounded-circle{{/if}}" href="{{this.url}}">{{this.page}}</a>
                            </li>
                        {{/if}}
                    {{/each}}
                </ul>
            </nav>
            {{/if}}
        {{/if}}

