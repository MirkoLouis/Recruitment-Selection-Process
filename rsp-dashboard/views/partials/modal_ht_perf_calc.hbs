    <!-- Higher Teaching Performance Calculator Modal -->
    <div class="modal fade glass-modal" id="htPerfCalcModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold" id="htPerfModalTitle">Higher Teaching Performance</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="htPerfModalBody">
                    <p class="text-muted small mb-3">Enter the School Year, Score, and Score Grade for the last 3 rating periods.</p>
                    
                    <div class="mb-3">
                        <div class="d-flex gap-2 w-100 mb-2">
                            <input type="text" class="form-control" id="htPerfSy1" placeholder="School Year 1" style="flex: 1;">
                            <input type="number" step="any" class="form-control" id="htPerfScore1" placeholder="Score" style="flex: 1;" oninput="calculateHtPerfPoints()">
                            <input type="text" class="form-control" id="htPerfGrade1" placeholder="Score Grade" style="flex: 1;">
                        </div>
                        <div class="d-flex gap-2 w-100 mb-2">
                            <input type="text" class="form-control" id="htPerfSy2" placeholder="School Year 2" style="flex: 1;">
                            <input type="number" step="any" class="form-control" id="htPerfScore2" placeholder="Score" style="flex: 1;" oninput="calculateHtPerfPoints()">
                            <input type="text" class="form-control" id="htPerfGrade2" placeholder="Score Grade" style="flex: 1;">
                        </div>
                        <div class="d-flex gap-2 w-100 mb-2">
                            <input type="text" class="form-control" id="htPerfSy3" placeholder="School Year 3" style="flex: 1;">
                            <input type="number" step="any" class="form-control" id="htPerfScore3" placeholder="Score" style="flex: 1;" oninput="calculateHtPerfPoints()">
                            <input type="text" class="form-control" id="htPerfGrade3" placeholder="Score Grade" style="flex: 1;">
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
                        <span class="text-muted fw-bold">Calculated Average:</span>
                        <span class="fs-4 fw-bold text-success" id="calculatedHtPerfPoints">0.000</span>
                    </div>
                    
                    <button type="button" id="htPerfApplyBtn" class="btn btn-info text-white w-100 fw-bold shadow-sm" onclick="applyHtPerfPoints()">
                        <i class="bi bi-check-circle"></i> Apply Points
                    </button>
                </div>
            </div>
        </div>
    </div>
