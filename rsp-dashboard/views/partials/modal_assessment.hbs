    <!-- Step 2 Assessment Modal (Template for all categories) -->
    <div class="modal fade glass-modal" id="assessmentModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-bottom border-light border-opacity-25 bg-info bg-opacity-10 text-info">
                    <h5 class="modal-title fw-bold"><i class="bi bi-card-checklist"></i> Evaluative Assessment</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="assessmentForm">
                        <input type="hidden" id="assessmentApplicantId">
                        <h5 id="assessmentApplicantName" class="text-center text-info fw-bold mb-3"></h5>
                        <p class="text-center text-muted mb-4">Category: <span id="assessmentCategory" class="fw-bold">Non-Teaching</span> | Position: <span id="assessmentPosition" class="fw-bold">-</span> | Salary Grade: <span id="assessmentSG" class="fw-bold">-</span></p>

                        <div class="table-responsive">
                            <table class="table table-bordered align-middle table-sm">
                                <thead class="table-light">
                                    <tr>
                                        <th>Criteria</th>
                                        <th class="text-center" style="width: 150px;">Score</th>
                                        <th class="text-center" style="width: 150px;">Max Points</th>
                                    </tr>
                                </thead>
                                <tbody id="assessmentCriteriaBody">
                                </tbody>
                                <tfoot>
                                    <tr class="fw-bold table-light">
                                        <td class="text-end">Total Score</td>
                                        <td class="text-center text-info fs-5" id="assessmentTotalScore">0</td>
                                        <td class="text-center text-secondary fs-5" id="assessmentMaxTotal">100</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                        
                        <div class="mt-3">
                            <label for="assessmentRemarks" class="form-label fw-bold">Remarks (CAR)</label>
                            <textarea class="form-control" name="remarks" id="assessmentRemarks" rows="2" placeholder="Optional remarks for CAR..."></textarea>
                        </div>

                        <div class="mt-4 row g-2">
                            <div class="col-4">
                                <button type="button" class="btn btn-warning text-dark w-100 btn-lg shadow-sm fw-bold" onclick="markNoAppearance()">
                                    <i class="bi bi-person-x me-1"></i> No Appearance
                                </button>
                            </div>
                            <div class="col-4">
                                <button type="button" class="btn btn-primary text-white w-100 btn-lg shadow-sm fw-bold" onclick="markNewlyPromoted()">
                                    <i class="bi bi-star me-1"></i> Newly Promoted
                                </button>
                            </div>
                            <div class="col-4">
                                <button type="submit" class="btn btn-info text-white w-100 btn-lg shadow-sm fw-bold">
                                    <i class="bi bi-save me-1"></i> Save Assessment
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
