<!-- Modals (Hidden from print) -->
<div class="d-print-none">    <!-- Qualify Modal -->
    <div class="modal fade glass-modal" id="qualifyModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">Qualify Applicant</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="qualifyForm">
                        <input type="hidden" id="qualifyId">
                        <p>Qualifying <strong id="qualifyName" class="text-primary"></strong></p>
                        <button type="submit" class="btn btn-success w-100">Confirm Qualification</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Score Modal -->
    <div class="modal fade glass-modal" id="scoreModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">Input Interview Score</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="scoreForm">
                        <input type="hidden" id="scoreId">
                        <p>Applicant: <strong id="scoreName" class="text-info"></strong></p>
                        <div class="mb-3">
                            <label class="form-label">Score (0-100)</label>
                            <input type="number" class="form-control form-control-lg text-center fw-bold fs-3" id="interviewScore" min="0" max="100" required>
                        </div>
                        <button type="submit" class="btn btn-info text-white w-100">Submit Assessment</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Requirements Modal (Moved to partial) -->
    {{> modal_requirements}}

    <!-- Assign Modal -->
    <div class="modal fade glass-modal" id="assignModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">Assign Office / School</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="assignForm">
                        <input type="hidden" id="assignId">
                        <p>Assigning: <strong id="assignName" class="text-success"></strong></p>
                        <div class="mb-4">
                            <label class="form-label">Assigned Office / School</label>
                            <input type="text" class="form-control" id="assignedOffice" required placeholder="e.g. IT Department">
                        </div>
                        <button type="submit" class="btn btn-success text-white w-100">Confirm Assignment</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Personal Info Modal -->
    <div class="modal fade glass-modal" id="infoModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">Personal Information</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="infoModalBody">
                    <!-- Populated via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Education Modal -->
    <div class="modal fade glass-modal" id="eduModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold" id="eduModalTitle">Education Records</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="eduModalBody">
                    <!-- Populated via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Training Modal -->
    <div class="modal fade glass-modal" id="trainModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold" id="trainModalTitle">Training Seminars</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="trainModalBody">
                    <!-- Populated via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Experience Modal -->
    <div class="modal fade glass-modal" id="expModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold" id="expModalTitle">Work Experience</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="expModalBody">
                    <!-- Populated via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Eligibility Modal -->
    <div class="modal fade glass-modal" id="eligModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold" id="eligModalTitle">Eligibility</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="eligModalBody">
                    <!-- Populated via JS -->
                </div>
            </div>
        </div>
    </div>
    
    {{> modal_delete_confirm}}
</div>

    <!-- Step 2 Summary Modal -->
    <div class="modal fade" id="summaryModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content glass-modal shadow-lg border-0">
                <div class="modal-header border-bottom border-light border-opacity-25 bg-primary bg-opacity-10 text-primary">
                    <h5 class="modal-title fw-bold"><i class="bi bi-card-checklist"></i> Applicant Summary</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <input type="hidden" id="summaryApplicantId">
                    <h5 id="summaryApplicantName" class="text-center text-primary fw-bold mb-4"></h5>
                    
                    <div id="summaryDetails">
                        <!-- Populated by main.js -->
                    </div>

                    <hr class="my-4 border-secondary border-opacity-25">
                    
                    
                    <div class="d-flex gap-2 mt-4">
                        <button type="button" class="btn btn-success flex-grow-1 w-50 btn-lg shadow-sm fw-bold" id="summaryQualifyBtn">
                            <i class="bi bi-check-circle me-1"></i> Qualify (Move to Step 2)
                        </button>
                        <button type="button" class="btn btn-warning flex-grow-1 w-50 btn-lg shadow-sm fw-bold text-dark" id="summaryDisqualifyBtn">
                            <i class="bi bi-x-circle me-1"></i> Disqualify
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Application Success Modal -->
    <div class="modal fade" id="successModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content glass-modal shadow-lg border-0 text-center">
                <div class="modal-body p-5">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                    <h3 class="mt-4 fw-bold">Application Successful!</h3>
                    <p class="text-muted mb-2">The applicant has been added.</p>
                    <p class="text-muted">Application Code:</p>
                    <h2 class="text-primary font-monospace fw-bold mb-4" id="successApplicationCode"></h2>
                    <div class="d-flex justify-content-center gap-2">
                        <button type="button" class="btn btn-light border px-4 fw-bold shadow-sm" data-bs-dismiss="modal" id="successModalCloseBtn">Close</button>
                        <button type="button" class="btn btn-primary px-4 fw-bold shadow-sm" data-bs-dismiss="modal" id="successModalProceedBtn">Proceed</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
