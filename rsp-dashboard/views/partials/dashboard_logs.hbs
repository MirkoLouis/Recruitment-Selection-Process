<div class="tab-pane fade" id="logs" role="tabpanel">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-semibold">System Logs</h4>
        <button class="btn btn-outline-secondary btn-sm" onclick="fetchLogs()">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>

    <div class="table-responsive bg-white rounded-3 shadow-sm border p-3" style="max-height: 600px; overflow-y: auto;">
        <table class="table table-hover table-sm align-middle mb-0" id="logsTable">
            <thead class="table-light sticky-top">
                <tr>
                    <th>Timestamp</th>
                    <th>User</th>
                    <th>Action</th>
                    <th>Target</th>
                </tr>
            </thead>
            <tbody>
                <!-- Populated by JS -->
            </tbody>
        </table>
    </div>
</div>
