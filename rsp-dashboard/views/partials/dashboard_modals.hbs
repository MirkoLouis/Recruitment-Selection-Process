<div class="d-print-none">
    <!-- Unified Applicant Details Modal -->
    <div class="modal fade glass-modal" id="unifiedDetailsModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0 bg-primary bg-opacity-10 text-primary">
                    <h5 class="modal-title fw-bold"><i class="bi bi-card-list me-2"></i>Applicant Details: <span id="unifiedModalName" class="text-dark"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center p-4">
                    <input type="hidden" id="unifiedModalId">
                    <input type="hidden" id="unifiedModalAssignedOffice">
                    <input type="hidden" id="unifiedModalCategory">
                    <input type="hidden" id="unifiedModalAppCode">
                    <input type="hidden" id="unifiedModalStatus">
                    
                    <h6 class="text-start fw-bold mb-3 border-bottom pb-2 text-muted">Step 1: Document Checks</h6>
                    <div class="d-flex flex-wrap gap-2 justify-content-center mb-4">
                        <button class="btn btn-outline-primary shadow-sm flex-grow-1" onclick="launchFromUnified('info')"><i class="bi bi-person-badge"></i> Info</button>
                        <button class="btn btn-outline-info shadow-sm flex-grow-1" onclick="launchFromUnified('edu')"><i class="bi bi-mortarboard-fill"></i> Education</button>
                        <button class="btn btn-outline-warning shadow-sm flex-grow-1" onclick="launchFromUnified('train')"><i class="bi bi-award-fill"></i> Training</button>
                        <button class="btn btn-outline-success shadow-sm flex-grow-1" onclick="launchFromUnified('exp')"><i class="bi bi-briefcase-fill"></i> Experience</button>
                        <button class="btn btn-outline-secondary shadow-sm flex-grow-1" onclick="launchFromUnified('elig')"><i class="bi bi-shield-check"></i> Eligibility</button>
                        <div class="d-flex w-100 gap-2 mt-2">
                            <button class="btn btn-primary shadow-sm w-50" onclick="launchFromUnified('step1_summary')"><i class="bi bi-card-checklist"></i> Document Summary</button>
                            <button class="btn btn-outline-danger shadow-sm w-50" id="unifiedBtnStep1Pdf" onclick="launchFromUnified('step1_pdf')"><i class="bi bi-file-earmark-word"></i> Generate DOC (Eval)</button>
                        </div>
                    </div>

                    <h6 class="text-start fw-bold mb-3 border-bottom pb-2 text-muted">Step 2 & 3: Assessment</h6>
                    <div class="d-flex flex-wrap gap-2 justify-content-center mb-4">
                        <button class="btn btn-info text-white shadow-sm flex-grow-1" id="unifiedBtnEval" onclick="launchFromUnified('eval_assessment')"><i class="bi bi-clipboard-check"></i> Evaluative Assessment</button>
                        <button class="btn btn-primary shadow-sm flex-grow-1" id="unifiedBtnAssessSum" onclick="launchFromUnified('step2_summary')"><i class="bi bi-clipboard-data"></i> Assessment Summary</button>
                    </div>

                    <h6 class="text-start fw-bold mb-3 border-bottom pb-2 text-muted">Step 4 & 5: Requirements & Action</h6>
                    <div class="d-flex flex-wrap gap-2 justify-content-center">
                        <button class="btn btn-outline-primary shadow-sm flex-grow-1" id="unifiedBtnReq" onclick="launchFromUnified('requirements')"><i class="bi bi-list-check"></i> View Requirements</button>
                        <button class="btn btn-outline-danger shadow-sm flex-grow-1" id="unifiedBtnPdf" onclick="launchFromUnified('generate_pdf')"><i class="bi bi-file-earmark-word"></i> Generate DOC</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Add Applicant Modal -->
    <div class="modal fade glass-modal" id="addApplicantModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-bottom-0 bg-primary bg-opacity-10 text-primary pb-3">
                    <h5 class="modal-title fw-bold"><i class="bi bi-person-plus-fill me-2"></i><span id="addApplicantModalTitle">New Applicant Wizard</span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="addApplicantForm">
                        <!-- Step 0: Category & Position -->
                        <div id="wizardStep0">
                            <h6 class="mb-3 text-center fw-bold">Select Applicant Category</h6>
                            <div class="row g-3 mb-3" id="categorySelection">
                                <div class="col-6"><button type="button" class="btn btn-outline-primary w-100 py-3 fw-semibold" onclick="selectCategory('Teaching')">Teaching</button></div>
                                <div class="col-6"><button type="button" class="btn btn-outline-primary w-100 py-3 fw-semibold" onclick="selectCategory('Related Teaching')">Related Teaching</button></div>
                                <div class="col-6"><button type="button" class="btn btn-outline-primary w-100 py-3 fw-semibold" onclick="selectCategory('School Administration')">School Administration</button></div>
                                <div class="col-6"><button type="button" class="btn btn-outline-primary w-100 py-3 fw-semibold" onclick="selectCategory('Non-Teaching')">Non-Teaching</button></div>
                            </div>
                            
                            <div id="positionSelection" class="d-none">
                                <div class="d-flex align-items-center mb-3">
                                    <button type="button" class="btn btn-sm btn-light me-2" onclick="backToCategories()"><i class="bi bi-arrow-left"></i></button>
                                    <h6 class="mb-0 fw-bold" id="selectedCategoryTitle">Select Position</h6>
                                </div>
                                <div class="list-group" id="positionList">
                                    <!-- Populated via JS -->
                                </div>
                            </div>
                        </div>

                        <!-- Step 1: Personal Info -->
                        <div id="wizardStep1" class="d-none">
                            <div class="d-flex align-items-center mb-3">
                                <button type="button" class="btn btn-sm btn-light me-2" onclick="backToPositions()"><i class="bi bi-arrow-left"></i></button>
                                <h6 class="mb-0 fw-bold text-primary">Personal Information</h6>
                            </div>
                            <input type="hidden" name="category" id="wizardCategory">
                            <input type="hidden" name="position" id="wizardPosition">
                            <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">First Name</label>
                                <input type="text" class="form-control" name="firstName" required placeholder="e.g. John">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Middle Name</label>
                                <input type="text" class="form-control" name="middleName" placeholder="e.g. Smith">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Last Name</label>
                                <input type="text" class="form-control" name="lastName" required placeholder="e.g. Doe">
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Address</label>
                                <input type="text" class="form-control" name="address">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Birthdate</label>
                                <input type="date" class="form-control" name="birthdate">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Sex</label>
                                <select class="form-select" name="sex">
                                    <option value="">Select...</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Civil Status</label>
                                <input type="text" class="form-control" name="civilStatus">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Religion</label>
                                <input type="text" class="form-control" name="religion">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Disability</label>
                                <input type="text" class="form-control" name="disability">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Ethnic Group</label>
                                <input type="text" class="form-control" name="ethnicGroup">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" name="emailAddress" placeholder="Email">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Contact No.</label>
                                <input type="text" class="form-control" name="contactNo" placeholder="Contact">
                            </div>
                        </div>
                        <div class="d-flex justify-content-end mt-4">
                            <button type="submit" class="btn btn-primary">Save & Next: Education <i class="bi bi-arrow-right"></i></button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Qualify Modal -->
    <div class="modal fade glass-modal" id="qualifyModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">Qualify Applicant</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="qualifyForm">
                        <input type="hidden" id="qualifyId">
                        <p>Qualifying <strong id="qualifyName" class="text-primary"></strong></p>
                        <button type="submit" class="btn btn-success w-100">Confirm Qualification</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    {{> modal_proceed}}

    <!-- Score Modal -->
    <div class="modal fade glass-modal" id="scoreModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">Input Interview Score</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="scoreForm">
                        <input type="hidden" id="scoreId">
                        <p>Applicant: <strong id="scoreName" class="text-info"></strong></p>
                        <div class="mb-3">
                            <label class="form-label">Score (0-100)</label>
                            <input type="number" class="form-control form-control-lg text-center fw-bold fs-3" id="interviewScore" min="0" max="100" required>
                        </div>
                        <button type="submit" class="btn btn-info text-white w-100">Submit Assessment</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Requirements Modal (Moved to partial) -->
    {{> modal_requirements}}

    <!-- Assign Modal -->
    <div class="modal fade glass-modal" id="assignModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">Assign Office / School</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="assignForm">
                        <input type="hidden" id="assignId">
                        <p>Assigning: <strong id="assignName" class="text-success"></strong></p>
                        <div class="mb-4">
                            <label class="form-label">Assigned Office / School</label>
                            <input type="text" class="form-control" id="assignedOffice" required placeholder="e.g. IT Department">
                        </div>
                        <button type="submit" class="btn btn-success text-white w-100">Confirm Assignment</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <!-- Document Type Modal -->
    <div class="modal fade glass-modal" id="docTypeModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold text-primary"><i class="bi bi-file-earmark-word"></i> Generate Document</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body pb-4">
                    <p class="text-muted small mb-3">Select the type of Assignment Order document to generate.</p>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Document Type</label>
                        <select class="form-select" id="docTypeSelect">
                            <option value="school">Assignment Order - School-Based</option>
                            <option value="division">Assignment Order - Division Office</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light shadow-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary shadow-sm" onclick="window.downloadSelectedDoc()">
                        <i class="bi bi-download"></i> Download
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Personal Info Modal -->
    <div class="modal fade glass-modal" id="infoModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">Personal Information</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="infoModalBody">
                    <!-- Populated via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Education Modal -->
    <div class="modal fade glass-modal" id="eduModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold" id="eduModalTitle">Education Records</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="eduModalBody">
                    <!-- Populated via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Training Modal -->
    <div class="modal fade glass-modal" id="trainModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold" id="trainModalTitle">Training Seminars</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="trainModalBody">
                    <!-- Populated via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Experience Modal -->
    <div class="modal fade glass-modal" id="expModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold" id="expModalTitle">Work Experience</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="expModalBody">
                    <!-- Populated via JS -->
                </div>
            </div>
        </div>
    </div>

    <!-- Eligibility Modal -->
    <div class="modal fade glass-modal" id="eligModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold" id="eligModalTitle">Eligibility</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="eligModalBody">
                    <!-- Populated via JS -->
                </div>
            </div>
        </div>
    </div>
    
    {{> modal_assessment}}
    {{> modal_edu_calc}}
    {{> modal_train_calc}}
    {{> modal_exp_calc}}
    {{> modal_perf_calc}}
    {{> modal_out_acc_calc}}
    {{> modal_app_edu_calc}}
    {{> modal_app_l_n_d_calc}}
    {{> modal_potential_calc}}
    {{> modal_step2_summary}}
    {{> modal_step3_confirm}}
    {{> modal_summary_disqualify}}
    {{> modal_step3_remove_no_appearance}}
</div>

    <!-- Plantilla Setup Modal -->
    <div class="modal fade glass-modal" id="plantillaModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-bottom border-light border-opacity-25 bg-success bg-opacity-10 text-success">
                    <h5 class="modal-title fw-bold"><i class="bi bi-list-ol me-2"></i> Plantilla Setup: <span id="plantillaModalTitle"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="plantillaForm">
                        <input type="hidden" name="id" id="plantillaPosId">
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold">How many vacancy in this position?</label>
                            <input type="number" class="form-control form-control-lg text-center fw-bold fs-3" name="vacancyCount" id="plantillaVacancyCount" min="1" max="100" required>
                        </div>
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold">Plantilla Item/s Number</label>
                            <div id="plantillaItemsContainer" class="d-flex flex-column gap-2">
                                <!-- Dynamic inputs will be inserted here -->
                            </div>
                        </div>
                        
                        <button type="submit" class="btn btn-success w-100 fw-bold shadow-sm" id="savePlantillaBtn">
                            <i class="bi bi-save me-2"></i> Save Plantilla
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Position Info Modal -->
    <div class="modal fade glass-modal" id="positionInfoModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-bottom border-light border-opacity-25 bg-primary bg-opacity-10 text-primary">
                    <h5 class="modal-title fw-bold"><i class="bi bi-file-earmark-ruled me-2"></i> <span id="positionInfoModalTitle">Position Info</span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="positionForm">
                        <input type="hidden" name="id" id="modalPosId">
                        
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small text-muted">Vacancy Announcement No.</label>
                                <input type="text" class="form-control bg-white bg-opacity-75" name="vacancyAnnouncement" id="modalPosVacancy">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-semibold small text-muted">Salary Grade</label>
                                <input type="text" class="form-control bg-white bg-opacity-75" name="salaryGrade" id="modalPosSalaryGrade">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-semibold small text-muted">Monthly Salary</label>
                                <input type="text" class="form-control bg-white bg-opacity-75" name="monthlySalary" id="modalPosMonthlySalary">
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-12">
                                <label class="form-label fw-semibold small text-muted">Plantilla Item/s Number</label>
                                <input type="hidden" name="plantillaItem" id="modalPosPlantillaHidden">
                                <div id="modalPosPlantillaList" class="bg-light text-muted rounded p-2 border" style="min-height: 38px;">
                                    <!-- Populated by JS -->
                                </div>
                            </div>
                        </div>

                        <h5 class="fw-bold mb-3 border-bottom pb-2">Qualification Standards</h5>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small text-muted">Education</label>
                                <textarea class="form-control bg-white bg-opacity-75" name="qsEducation" id="modalPosEdu" rows="3" placeholder="Enter Education Requirement..."></textarea>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small text-muted">Training</label>
                                <textarea class="form-control bg-white bg-opacity-75" name="qsTraining" id="modalPosTrain" rows="3" placeholder="Enter Training Requirement..."></textarea>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small text-muted">Experience</label>
                                <textarea class="form-control bg-white bg-opacity-75" name="qsExperience" id="modalPosExp" rows="3" placeholder="Enter Experience Requirement..."></textarea>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small text-muted">Eligibility</label>
                                <textarea class="form-control bg-white bg-opacity-75" name="qsEligibility" id="modalPosElig" rows="3" placeholder="Enter Eligibility requirement..."></textarea>
                            </div>
                        </div>
                        
                        <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                            <button type="submit" class="btn btn-primary px-4 shadow-sm fw-bold" id="savePositionBtn">
                                <i class="bi bi-save me-2"></i> Save Standards
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Step 2 Summary Modal -->
    <div class="modal fade" id="summaryModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content glass-modal shadow-lg border-0">
                <div class="modal-header border-bottom border-light border-opacity-25 bg-primary bg-opacity-10 text-primary">
                    <h5 class="modal-title fw-bold"><i class="bi bi-card-checklist"></i> Applicant Summary</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <input type="hidden" id="summaryApplicantId">
                    <h5 id="summaryApplicantName" class="text-center text-primary fw-bold mb-4"></h5>
                    
                    <div id="summaryDetails">
                        <!-- Populated by main.js -->
                    </div>

                    <hr class="my-4 border-secondary border-opacity-25">
                    
                    
                    <div class="d-flex gap-2 mt-4">
                        <button type="button" class="btn btn-success flex-grow-1 w-50 btn-lg shadow-sm fw-bold" id="summaryQualifyBtn">
                            <i class="bi bi-check-circle me-1"></i> Qualify (Move to Step 2)
                        </button>
                        <button type="button" class="btn btn-warning flex-grow-1 w-50 btn-lg shadow-sm fw-bold text-dark" id="summaryDisqualifyBtn">
                            <i class="bi bi-x-circle me-1"></i> Disqualify
                        </button>
                    </div>
        </div>
    </div>

    <!-- Update Status Modal -->
    <div class="modal fade glass-modal" id="updateStatusModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0">
                <div class="modal-header border-bottom-0 pb-0 bg-warning bg-opacity-10 text-dark">
                    <h5 class="modal-title fw-bold"><i class="bi bi-pencil me-2"></i>Update Applicant Status</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <form id="updateStatusForm">
                        <input type="hidden" id="updateStatusId">
                        <p>Applicant: <strong id="updateStatusName" class="text-primary"></strong></p>
                        
                        <div class="mb-4">
                            <label class="form-label fw-semibold text-muted">Select New Status</label>
                            <select class="form-select bg-white bg-opacity-75" id="updateStatusSelect" required>
                                <option value="PENDING">Step 1: Pending</option>
                                <option value="WAITING_FOR_ASSESSMENT">Step 2: Qualified for Deliberation</option>
                                <option value="ASSESSED">Step 3: Assessed</option>
                                <option value="WAITING">Step 4: Requirements</option>
                                <option value="ASSIGNED">Step 5: Assigned</option>
                                <option value="COMPLETED">Completed</option>
                                <option value="DISQUALIFIED">Disqualified</option>
                            </select>
                            <div class="form-text mt-2">
                                Changing status will manually move the applicant to the selected step. For example, if they were disqualified, set them back to "Step 1: Pending" or "Step 2: Qualified".
                            </div>
                        </div>
                        
