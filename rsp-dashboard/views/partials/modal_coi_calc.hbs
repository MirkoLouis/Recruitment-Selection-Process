<!-- PPST COIs Calculator Modal -->
<div class="modal fade glass-modal" id="coiCalcModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-info"><i class="bi bi-calculator"></i> Calculate PPST COIs Points</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pb-4">
                <div class="mb-3">
                    <label class="form-label fw-bold">COT Rating (x) [Max 30]</label>
                    <input type="number" class="form-control" id="coiRatingInput" placeholder="e.g. 20" step="0.01" min="0" max="30" oninput="calculateCoiPoints()">
                    <div class="form-text">Formula: (COT Rating / 30) * 35</div>
                </div>
                
                <div class="p-3 bg-light rounded-3 text-center mb-0 border">
                    <span class="text-muted d-block mb-1">Calculated Points</span>
                    <h3 class="fw-bold text-success mb-0" id="calculatedCoiPoints">0</h3>
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-light shadow-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success shadow-sm" onclick="applyCoiPoints()">
                    <i class="bi bi-check-circle"></i> Apply Points
                </button>
            </div>
        </div>
    </div>
</div>
