    <!-- Performance Calculator Modal -->
    <div class="modal fade glass-modal" id="perfCalcModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header border-bottom border-light border-opacity-25 bg-info bg-opacity-10 text-info">
                    <h5 class="modal-title fw-bold"><i class="bi bi-graph-up-arrow"></i> Performance Points Calculator</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Evaluation Method</label>
                        <select class="form-select mb-2" id="perfEvalMethod" onchange="togglePerfInputs(); calculatePerfPoints()">
                            <option value="rpms">Performance Rating (RPMS 5-point scale)</option>
                            <option value="rpms10">Performance Rating (RPMS 10-point scale)</option>
                            <option value="gwa">CS Eligibility / Board Exam / GWA (100-point scale)</option>
                            <option value="summa">Honor Graduate - Summa Cum Laude (Auto 20 pts)</option>
                            <option value="magna">Honor Graduate - Magna Cum Laude (Auto 19 pts)</option>
                            <option value="cum">Honor Graduate - Cum Laude (Auto 18 pts)</option>
                        </select>
                    </div>

                    <div class="mb-3" id="perfRatingDiv">
                        <label class="form-label fw-bold" id="perfRatingLabel">Rating (x)</label>
                        <input type="number" class="form-control" id="perfRatingInput" step="0.001" max="5" placeholder="e.g. 4.356" oninput="if(this.max && parseFloat(this.value) > parseFloat(this.max)) this.value = this.max; calculatePerfPoints();">
                        <div class="form-text" id="perfRatingHelp">Enter RPMS rating (0-5) or midpoint value.</div>
                        <div class="mt-2" id="midpointHelperDiv">
                            <label class="form-label small text-muted">Midpoint Helper (External Applicants)</label>
                            <select class="form-select form-select-sm" id="perfMidpointHelper" onchange="applyMidpoint()">
                                <option value="">-- Select Adjectival Rating --</option>
                                <option value="4.75">Outstanding (4.500 - 5.000)</option>
                                <option value="3.995">Very Satisfactory (3.500 - 4.499)</option>
                                <option value="2.995">Satisfactory (2.500 - 3.499)</option>
                                <option value="1.995">Unsatisfactory (1.500 - 2.499)</option>
                                <option value="0.7495">Poor (Below 1.500)</option>
                            </select>
                        </div>
                    </div>

                    <hr class="my-4 border-secondary border-opacity-25">

                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted fw-bold">Weight Allocation (WA):</span>
                        <span class="fs-5 fw-bold text-primary" id="perfWA">0</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="text-muted fw-bold">Calculated Points:</span>
                        <span class="fs-4 fw-bold text-success" id="calculatedPerfPoints">0.000</span>
                    </div>
                    
                    <button type="button" class="btn btn-info text-white w-100 fw-bold shadow-sm" onclick="applyPerfPoints()">
                        <i class="bi bi-check-circle"></i> Apply Points
                    </button>
                </div>
            </div>
        </div>
    </div>
