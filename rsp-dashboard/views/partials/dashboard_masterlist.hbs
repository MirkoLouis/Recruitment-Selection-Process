        <!-- Masterlist Tab -->
        <div class="tab-pane fade {{#if showMasterlist}}show active{{/if}}" id="masterlist" role="tabpanel">
            <div class="glass-panel p-4 rounded-4 shadow-sm h-100 position-relative">
                <div class="mb-3">
                    <form method="GET" action="/dashboard" class="row g-2">
                        <input type="hidden" name="tab" value="masterlist">
                        <div class="col-md-3">
                            <div class="input-group glass-panel h-100 shadow-sm">
                                <span class="input-group-text bg-white border-end-0 cursor-pointer" onclick="this.closest('form').submit()"><i class="bi bi-search text-primary"></i></span>
                                <input type="text" name="q" class="form-control border-start-0 ps-0" placeholder="Search by name or applicant code..." value="{{searchQuery}}" onkeypress="if(event.key === 'Enter') this.form.submit();">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="glass-panel h-100 px-2 py-1 shadow-sm bg-white">
                                <select name="position" class="form-select border-0 shadow-none bg-transparent custom-ui-select" onchange="if(this.form.vacancy) this.form.vacancy.value=''; if(this.form.step) this.form.step.value=''; if(this.form.remarks) this.form.remarks.value=''; if(this.form.office) this.form.office.value=''; this.form.submit()">
                                    <option value="">All Positions</option>
                                    {{#each positionList}}
                                    <option value="{{this}}" {{#if (eq ../positionFilter this)}}selected{{/if}}>{{this}}</option>
                                    {{/each}}
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="glass-panel h-100 px-2 py-1 shadow-sm bg-white">
                                <select name="vacancy" class="form-select border-0 shadow-none bg-transparent custom-ui-select" onchange="this.form.submit()">
                                    <option value="">All Vacancies</option>
                                    {{#each vacancyList}}
                                    <option value="{{this}}" {{#if (eq ../vacancyFilter this)}}selected{{/if}}>{{this}}</option>
                                    {{/each}}
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="glass-panel h-100 px-2 py-1 shadow-sm bg-white">
                                <select name="step" class="form-select border-0 shadow-none bg-transparent custom-ui-select" onchange="this.form.submit()">
                                    <option value="">All Steps & Remarks</option>
                                    {{#each stepList}}
                                    <option value="{{this.value}}" {{#if (eq ../stepFilter this.value)}}selected{{/if}}>{{this.label}}</option>
                                    {{/each}}
                                </select>
                            </div>
                        </div>
                    </form>
                </div>

                <div class="rounded-4 shadow-sm border border-light table-responsive-wrapper bg-white">
                    <table class="table table-hover align-middle mb-0 bg-white custom-table">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4 pe-3 text-nowrap">Application Code</th>
                                <th class="px-3 w-100">Applicant Name</th>
                                <th class="px-4 text-nowrap">Current Step</th>
                                <th class="text-center px-4 text-nowrap">Applicant Details</th>
                                <th class="text-center pe-4 ps-3 text-nowrap">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each applicants}}
                            <tr>
                                <td class="ps-4 pe-3 text-nowrap"><span class="badge bg-secondary font-monospace">{{this.applicationCode}}</span></td>
                                <td class="fw-medium px-3 applicant-name-display-{{this.id}}">{{titleCase this.name}}</td>
                                <td class="px-4 text-nowrap">
                                    {{#if (eq this.status 'PENDING')}}
                                        {{#if (eq this.docRemark 'In-Prog')}}
                                            <span class="badge bg-info text-dark">Step 1: In Prog</span>
                                        {{else if (eq this.docRemark 'Assessed')}}
                                            <span class="badge bg-success">Step 1: Assessed</span>
                                        {{else}}
                                            <span class="badge bg-warning text-dark">Step 1: Pending</span>
                                        {{/if}}
                                    {{/if}}
                                    {{#if (eq this.status 'QUALIFIED')}}<span class="badge bg-success">Step 1: Qualified</span>{{/if}}
                                    {{#if (eq this.status 'DISQUALIFIED')}}<span class="badge bg-danger">Step 1: Disqualified</span>{{/if}}
                                    {{#if (eq this.status 'WAITING_FOR_ASSESSMENT')}}{{#if (eq this.assessmentRemarks 'In-Prog')}}<span class="badge bg-info text-dark">Step 2: In Prog</span>{{else if (eq this.assessmentRemarks 'Newly Promoted')}}<span class="badge bg-danger">Step 2: Newly Promoted</span>{{else}}<span class="badge bg-warning text-dark">Step 2: Pending</span>{{/if}}{{/if}}
                                    {{#if (eq this.status 'ASSESSED')}}<span class="badge bg-success">Step 3: Assessed</span>{{/if}}
                                    {{#if (eq this.status 'NO_APPEARANCE')}}<span class="badge bg-danger">Step 3: No Appearance</span>{{/if}}
                                    {{#if (eq this.status 'NEWLY_PROMOTED')}}<span class="badge bg-danger">Step 3: Newly Promoted</span>{{/if}}
                                    {{#if (eq this.status 'WAITING')}}{{#if (eq this.assignmentReqStatus 'COMPLETE')}}<span class="badge shadow-sm border border-light" style="background-color: purple; color: white;">Step 4: Generated</span>{{else}}<span class="badge bg-warning text-dark">Step 4: Pending</span>{{/if}}{{/if}}
                                    {{#if (eq this.status 'ASSIGNED')}}<span class="badge bg-success shadow-sm border border-light">Step 5: Assigned</span>{{/if}}
                                    {{#if (eq this.status 'COMPLETED')}}<span class="badge shadow-sm border border-light" style="background-color: purple; color: white;">Step 5: Completed</span>{{/if}}
                                </td>
                                <td class="text-center px-4 text-nowrap">
                                    <button class="btn btn-sm btn-outline-primary action-btn shadow-sm px-2 py-1" onclick="openApplicantDetailsModal({{this.id}}, '{{titleCase this.name}}', '{{this.assignedOffice}}', '{{this.category}}', '{{this.applicationCode}}', '{{this.status}}')" title="Applicant Details"><i class="bi bi-card-list"></i> Details</button>
                                </td>
                                <td class="text-center pe-4 ps-3 text-nowrap">
                                    <div class="d-flex justify-content-center align-items-center gap-2">
                                        <button class="btn btn-sm btn-warning action-btn text-dark shadow-sm px-2 py-1" onclick="openUpdateStatusModal({{this.id}}, '{{titleCase this.name}}', '{{this.status}}')" title="Update Status"><i class="bi bi-pencil"></i> Update</button>
                                        <button class="btn btn-sm btn-danger action-btn shadow-sm px-2 py-1" onclick="deleteApplicant({{this.id}})" title="Delete Applicant"><i class="bi bi-trash"></i> Delete</button>
                                    </div>
                                </td>
                            </tr>
                            {{else}}
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2 text-secondary opacity-50"></i>
                                    No applicants found matching the criteria.
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>

                {{#if pagination.[1]}}
                <nav aria-label="Page navigation" class="mt-4">
                    <ul class="pagination flex-wrap justify-content-center mb-0">
                        {{#each pagination}}
                            {{#if this.isEllipsis}}
                                <li class="page-item disabled"><span class="page-link border-0 bg-transparent text-muted">...</span></li>
                            {{else}}
                                <li class="page-item {{#if this.isCurrent}}active{{/if}}">
                                    <a class="page-link mx-1 {{#if this.isCurrent}}shadow-sm{{/if}} {{#if @first}}page-first{{else if @last}}page-last{{else}}rounded-circle{{/if}}" href="{{this.url}}">{{this.page}}</a>
                                </li>
                            {{/if}}
                        {{/each}}
                    </ul>
                </nav>
                {{/if}}
            </div>
        </div>
