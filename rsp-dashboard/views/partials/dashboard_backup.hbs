        <!-- Backup Tab -->
        <div class="tab-pane fade {{#if showBackup}}show active{{/if}}" id="backup" role="tabpanel">
            <div class="row g-4 mb-4">
                <!-- System Backups -->
                <div class="col-lg-4 col-md-6">
                    <div class="card border-0 glass-panel shadow-sm rounded-4 h-100" style="background: linear-gradient(135deg, rgba(25,135,84,0.1) 0%, rgba(25,135,84,0.05) 100%); border-left: 5px solid #198754 !important;">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-4">
                                <div class="display-4 text-success fw-bold me-4"><i class="bi bi-database-fill-down"></i></div>
                                <div>
                                    <h3 class="fw-bold mb-1">Database Backup</h3>
                                    <p class="text-muted mb-0">Full backup of applicant records and data.</p>
                                </div>
                            </div>
                            <div class="d-flex flex-column gap-3 mt-4">
                                <button class="btn btn-success rounded-pill px-4 py-2 shadow-sm d-flex align-items-center justify-content-center" onclick="window.location.href='/api/export/backup'">
                                    <i class="bi bi-filetype-json fs-5 me-2"></i>
                                    <div class="text-start ms-2">
                                        <div class="fw-bold">JSON Format</div>
                                        <div class="small opacity-75" style="line-height:1;">Best for system restore</div>
                                    </div>
                                </button>
                                <button class="btn btn-outline-success rounded-pill px-4 py-2 shadow-sm d-flex align-items-center justify-content-center" onclick="window.location.href='/api/export/backup/csv'">
                                    <i class="bi bi-filetype-csv fs-5 me-2"></i>
                                    <div class="text-start ms-2">
                                        <div class="fw-bold">CSV Format (ZIP)</div>
                                        <div class="small opacity-75" style="line-height:1;">Best for spreadsheet analysis</div>
                                    </div>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Reports & Exports -->
                <div class="col-lg-4 col-md-6">
                    <div class="card border-0 glass-panel shadow-sm rounded-4 h-100" style="background: linear-gradient(135deg, rgba(13,110,253,0.1) 0%, rgba(13,110,253,0.05) 100%); border-left: 5px solid #0d6efd !important;">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-4">
                                <div class="display-4 text-primary fw-bold me-4"><i class="bi bi-file-earmark-text-fill"></i></div>
                                <div>
                                    <h3 class="fw-bold mb-1">Reports & Exports</h3>
                                    <p class="text-muted mb-0">Generate documents and evaluation registers.</p>
                                </div>
                            </div>
                            <div class="d-flex flex-column gap-3 mt-4">
                                <button class="btn btn-primary rounded-pill px-4 py-2 shadow-sm d-flex align-items-center justify-content-center" onclick="window.location.href='/api/positions/export/doc'">
                                    <i class="bi bi-file-earmark-word-fill fs-5 me-2"></i>
                                    <div class="text-start ms-2">
                                        <div class="fw-bold">Positions (Docx)</div>
                                        <div class="small opacity-75" style="line-height:1;">Export open positions document</div>
                                    </div>
                                </button>
                                <button class="btn btn-outline-primary rounded-pill px-4 py-2 shadow-sm d-flex align-items-center justify-content-center" onclick="window.location.href='/api/export/ver'">
                                    <i class="bi bi-file-earmark-excel-fill fs-5 me-2"></i>
                                    <div class="text-start ms-2">
                                        <div class="fw-bold">Vacancy Evaluation Register</div>
                                        <div class="small opacity-75" style="line-height:1;">Export VER to Excel</div>
                                    </div>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Email Notifications -->
                <div class="col-lg-4 col-md-12">
                    <div class="card border-0 glass-panel shadow-sm rounded-4 h-100" style="background: linear-gradient(135deg, rgba(111,66,193,0.1) 0%, rgba(111,66,193,0.05) 100%); border-left: 5px solid #6f42c1 !important;">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-4">
                                <div class="display-4 fw-bold me-4" style="color: #6f42c1;"><i class="bi bi-envelope-paper-fill"></i></div>
                                <div>
                                    <h3 class="fw-bold mb-1">Notifications</h3>
                                    <p class="text-muted mb-0">Email applicants their Application Codes.</p>
                                </div>
                            </div>
                            <div class="d-flex flex-column gap-3 mt-4">
                                <button class="btn rounded-pill px-4 py-2 shadow-sm d-flex align-items-center justify-content-center text-white" style="background-color: #6f42c1; border: none;" onclick="openEmailModal()">
                                    <i class="bi bi-send-fill fs-5 me-2"></i>
                                    <div class="text-start ms-2">
                                        <div class="fw-bold">Send Codes</div>
                                        <div class="small opacity-75" style="line-height:1;">Email selected applicants</div>
                                    </div>
                                </button>
                                <div class="text-center mt-2 small text-muted">
                                    <i class="bi bi-info-circle me-1"></i> <span id="dailyEmailLimitText">Loading limit...</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Email Selection Modal -->
        <div class="modal fade" id="emailSelectionModal" tabindex="-1" aria-labelledby="emailSelectionModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-xl modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold" id="emailSelectionModalLabel">Select Applicants</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small mb-3">Select the applicants you wish to send their application codes to.</p>


                        
                        <div class="row g-2 mb-3">
                            <div class="col-md-5">
                                <div class="input-group glass-panel shadow-sm">
                                    <span class="input-group-text bg-white border-end-0 cursor-pointer" onclick="filterEmailApplicants()"><i class="bi bi-search text-primary"></i></span>
                                    <input type="text" class="form-control border-start-0 ps-0" id="emailSearchName" placeholder="Search by name, code, or email..." onkeydown="if(event.key === 'Enter') { event.preventDefault(); filterEmailApplicants(); }">
                                </div>
                            </div>
                            <div class="col-md-4">
                                <select class="form-select rounded-pill" id="emailFilterPosition" onchange="updateVacancyFilterOptions(this.value); filterEmailApplicants();">
                                    <option value="">All Positions</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <select class="form-select rounded-pill" id="emailFilterVacancy" onchange="filterEmailApplicants()">
                                    <option value="">All Vacancies</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3 d-flex align-items-center justify-content-between">
                            <span class="badge bg-secondary" id="selectedCountBadge">0 Selected</span>
                        </div>

                        <div class="table-responsive border rounded-3" style="max-height: calc(100vh - 380px); overflow-y: auto;">
                            <table class="table table-hover align-middle mb-0" id="emailApplicantsTable">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th scope="col" style="width: 40px;">
                                            <input class="form-check-input mt-0" type="checkbox" id="selectAllEmails" onchange="toggleSelectAllEmails(this)">
                                        </th>
                                        <th scope="col">Applicant Name</th>
                                        <th scope="col">Code / Email</th>
                                        <th scope="col">Position & Vacancy</th>
                                        <th scope="col">Status</th>
                                    </tr>
                                </thead>
                                <tbody id="emailApplicantsList">
                                    <!-- Applicants will be loaded here dynamically -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn text-white rounded-pill px-4" style="background-color: #6f42c1;" id="sendEmailBtn" onclick="promptEmailConfirmation()">
                            <i class="bi bi-send-fill me-2"></i> Send to Selected
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Email Confirmation Modal -->
        <div class="modal fade" id="emailConfirmationModal" tabindex="-1" aria-labelledby="emailConfirmationModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold" id="emailConfirmationModalLabel">Confirm Email Dispatch</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure you want to send the application codes to the selected <strong id="confirmEmailCount">0</strong> applicant(s)?</p>
                        <p class="text-muted small mb-0">This action cannot be undone and will send emails immediately.</p>
                    </div>
                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn text-white rounded-pill px-4" style="background-color: #6f42c1;" id="confirmSendEmailBtn" onclick="confirmSubmitEmailCodes()">
                            <i class="bi bi-send-fill me-2"></i> Yes, Send Emails
                        </button>
                    </div>
                </div>
            </div>
        </div>
