        <!-- STEP 3 -->
        {{#if step3Active}}
            <h2 class="fw-semibold mb-3">Comparative Assessments</h2>
            <p class="text-muted">Official leaderboard of assessed applicants ranked by their total evaluation scores.</p>
            
            <div class="mb-3">
                
                <form method="GET" action="/step3/1" class="row g-2">
                    <div class="col-md-3">
                        <div class="input-group glass-panel h-100 shadow-sm">
                            <span class="input-group-text bg-white border-end-0 cursor-pointer" onclick="submitSearch(this.closest('form'))"><i class="bi bi-search text-primary"></i></span>
                            <input type="text" name="q" class="form-control border-start-0 ps-0" placeholder="Search by name or code..." value="{{searchQuery}}" onkeypress="if(event.key === 'Enter') { event.preventDefault(); submitSearch(this.form); }">
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="glass-panel filter-glass-panel h-100 px-2 py-1">
                            <select name="position" class="form-select bg-transparent border-0 shadow-none custom-ui-select" onchange="if(this.form.vacancy) this.form.vacancy.value=''; if(this.form.step) this.form.step.value=''; if(this.form.remarks) this.form.remarks.value=''; if(this.form.office) this.form.office.value=''; this.form.submit()">
                                <option value="">All Positions</option>
                                {{#each positionList}}
                                    <option value="{{this}}" {{#if (eq this ../positionFilter)}}selected{{/if}}>{{this}}</option>
                                {{/each}}
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="glass-panel filter-glass-panel h-100 px-2 py-1">
                            <select name="vacancy" class="form-select bg-transparent border-0 shadow-none custom-ui-select" onchange="this.form.submit()">
                                <option value="">All Vacancies</option>
                                {{#each vacancyList}}
                                    <option value="{{this}}" {{#if (eq this ../vacancyFilter)}}selected{{/if}}>{{this}}</option>
                                {{/each}}
                            </select>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="glass-panel filter-glass-panel h-100 px-2 py-1">
                            <select name="remarks" class="form-select bg-transparent border-0 shadow-none custom-ui-select" onchange="this.form.submit()">
                                <option value="">All Steps & Remarks</option>
                                {{#each remarksList}}
                                    <option value="{{this.value}}" {{#if (eq this.value ../remarksFilter)}}selected{{/if}}>{{this.label}}</option>
                                {{/each}}
                            </select>
                        </div>
                    </div>
                    <div class="col-md-auto ms-auto">
                        <button type="button" class="btn btn-outline-success h-100 px-3 d-flex align-items-center justify-content-center fw-semibold text-nowrap" style="white-space: nowrap;" onclick="handleCARDownloadClick()">
                            <i class="bi bi-file-earmark-spreadsheet me-2"></i> Download CAR
                        </button>
                    </div>
                </form>
            </div>

            <div class="rounded-3 shadow-sm table-responsive-wrapper bg-white">
                <table class="table table-hover align-middle mb-0 custom-table leaderboard" id="table-step3">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Application Code</th>
                            <th>Applicant Name</th>
                            <th>Position</th>
                            <th class="text-center">Score Summary</th>
                            <th class="text-center" style="width: 80px;">Rank</th>
                            <th class="text-center">Total</th>
                            <th class="text-center">Remarks</th>
                            <th class="text-end pe-4">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each step3}}
                        <tr>
                            <td class="ps-4"><span class="badge bg-secondary font-monospace">{{this.applicationCode}}</span></td>
                            <td class="fw-medium applicant-name-display-{{this.id}}">{{titleCase this.name}}</td>
                            <td>{{this.position}}</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-primary action-btn" onclick="openStep2SummaryModal({{this.id}}, '{{titleCase this.name}}', true)" title="View Summary">
                                    <i class="bi bi-eye"></i> View
                                </button>
                            </td>
                            <td class="fw-bold text-primary text-center">#{{incOffset @index ../offset}}</td>
                            <td class="text-center fw-bold {{#if (eq this.status 'NO_APPEARANCE')}}text-danger{{else if (eq this.status 'NEWLY_PROMOTED')}}text-danger{{else}}text-success{{/if}} fs-5">
                                {{#if (eq this.status 'NO_APPEARANCE')}}
                                    0
                                {{else if (eq this.status 'NEWLY_PROMOTED')}}
                                    0
                                {{else}}
                                    {{#unless (eq this.scores.total null)}}
                                        {{this.scores.total}}
                                    {{else}}
                                        -
                                    {{/unless}}
                                {{/if}}
                            </td>
                            <td class="text-center">
                                {{#if (eq this.status 'NO_APPEARANCE')}}
                                    <span class="badge bg-danger">No Appearance</span>
                                {{else if (eq this.status 'NEWLY_PROMOTED')}}
                                    <span class="badge bg-danger">Newly Promoted</span>
                                {{else}}
                                    <span class="badge bg-success">Assessed</span>
                                {{/if}}
                            </td>
                            <td class="text-end pe-4">
                                {{#if (eq this.status 'ASSESSED')}}
                                <button class="btn btn-sm btn-primary action-btn" onclick="proceedToRequirements({{this.id}}, '{{titleCase this.name}}')" title="Move to Step 4"><i class="bi bi-arrow-right-circle"></i> Move</button>
                                {{/if}}
                                {{#if (eq this.status 'NO_APPEARANCE')}}
                                <button class="btn btn-sm btn-danger action-btn" onclick="confirmRemoveNoAppearance({{this.id}}, '{{titleCase this.name}}')" title="Remove"><i class="bi bi-trash"></i> Remove</button>
                                {{/if}}
                                {{#if (eq this.status 'NEWLY_PROMOTED')}}
                                <button class="btn btn-sm btn-danger action-btn" onclick="confirmRemoveNoAppearance({{this.id}}, '{{titleCase this.name}}')" title="Remove"><i class="bi bi-trash"></i> Remove</button>
                                {{/if}}
                            </td>
                        </tr>
                        {{else}}
                        <tr><td colspan="8" class="text-center text-muted py-4">No comparative data available yet.</td></tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            
            {{#if pagination.[1]}}
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination flex-wrap justify-content-center mb-0">
                    {{#each pagination}}
                        {{#if this.isEllipsis}}
                            <li class="page-item disabled"><span class="page-link border-0 bg-transparent text-muted">...</span></li>
                        {{else}}
                            <li class="page-item {{#if this.isCurrent}}active{{/if}}">
                                <a class="page-link mx-1 {{#if this.isCurrent}}shadow-sm{{/if}} {{#if @first}}page-first{{else if @last}}page-last{{else}}rounded-circle{{/if}}" href="{{this.url}}">{{this.page}}</a>
                            </li>
                        {{/if}}
                    {{/each}}
                </ul>
            </nav>
            {{/if}}
        {{/if}}



