<!-- Step 1 Remove Applicant Modal -->
<div class="modal fade glass-modal" id="step1RemoveModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-danger"><i class="bi bi-x-circle"></i> Remove Applicant</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pb-4">
                <p class="mb-0">Are you sure you want to remove this disqualified applicant from Step 1? They will still remain in the Masterlist.</p>
                <input type="hidden" id="step1RemoveApplicantId">
            </div>
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-light shadow-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger shadow-sm" onclick="confirmRemoveApplicantFromStep1()">
                    <i class="bi bi-x-circle"></i> Remove
                </button>
            </div>
        </div>
    </div>
</div>
