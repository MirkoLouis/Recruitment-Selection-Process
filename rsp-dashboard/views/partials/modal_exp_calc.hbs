                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="text-muted fw-bold">Calculated Points:</span>
                        <span class="fs-4 fw-bold text-success" id="calculatedExpPoints">0</span>
                    </div>
                    
                    <button type="button" class="btn btn-success text-white w-100 fw-bold shadow-sm" onclick="applyExpPoints()">
                        <i class="bi bi-check-circle"></i> Apply Points
                    </button>
                </div>
