                            <option value="10">Level 10: 4 years 6 months - <5 years</option>
                            <option value="11">Level 11: 5 years - <5 years 6 months</option>
                            <option value="12">Level 12: 5 years 6 months - <6 years</option>
                            <option value="13">Level 13: 6 years - <6 years 6 months</option>
                            <option value="14">Level 14: 6 years 6 months - <7 years</option>
                            <option value="15">Level 15: 7 years - <7 years 6 months</option>
                            <option value="16">Level 16: 7 years 6 months - <8 years</option>
                            <option value="17">Level 17: 8 years - <8 years 6 months</option>
                            <option value="18">Level 18: 8 years 6 months - <9 years</option>
                            <option value="19">Level 19: 9 years - <9 years 6 months</option>
