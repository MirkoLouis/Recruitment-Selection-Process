                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Applicant's Experience Level</label>
                        <select class="form-select searchable-select" id="applicantExpLevel" onchange="calculateExpPoints()">
                            <option value="1">Level 1: Less than 6 months</option>
                            <option value="2">Level 2: 6 months - <1 year</option>
                            <option value="3">Level 3: 1 year - <1 year 6 months</option>
                            <option value="4">Level 4: 1 year 6 months - <2 years</option>
                            <option value="5">Level 5: 2 years - <2 years 6 months</option>
