<div class="modal fade glass-modal" id="plantillaModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-success" id="plantillaModalTitle">Setup Plantilla</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="plantillaForm">
                <div class="modal-body pb-4">
                    <input type="hidden" id="plantillaPosId" name="id">
                    <div class="mb-3 border rounded p-3">
                        <label class="form-label fw-semibold">Location 1</label>
                        <input type="text" class="form-control mb-2" id="plantillaLoc1" placeholder="Place of Assignment (e.g. School Division Office)">
                        <textarea class="form-control" id="plantillaItems1" rows="2" placeholder="Plantilla numbers separated by comma"></textarea>
                    </div>
                    <div class="mb-3 border rounded p-3">
                        <label class="form-label fw-semibold">Location 2</label>
                        <input type="text" class="form-control mb-2" id="plantillaLoc2" placeholder="Place of Assignment">
                        <textarea class="form-control" id="plantillaItems2" rows="2" placeholder="Plantilla numbers separated by comma"></textarea>
                    </div>
                    <div class="mb-3 border rounded p-3">
                        <label class="form-label fw-semibold">Location 3</label>
                        <input type="text" class="form-control mb-2" id="plantillaLoc3" placeholder="Place of Assignment">
                        <textarea class="form-control" id="plantillaItems3" rows="2" placeholder="Plantilla numbers separated by comma"></textarea>
                        <div class="form-text text-muted mt-2">Separate multiple item numbers with a comma. The vacancy count will be automatically calculated based on the total number of items across all locations.</div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light shadow-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary shadow-sm" id="savePlantillaBtn">
                        <i class="bi bi-save"></i> Save Setup
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
