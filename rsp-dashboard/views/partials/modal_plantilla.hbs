<style>
    .btn-light-blue {
        background-color: #e0f0ff;
        color: #0056b3;
        border: 1px solid #b3d7ff;
        transition: all 0.2s ease-in-out;
    }
    .btn-light-blue:hover {
        background-color: #0d6efd;
        color: white;
        border-color: #0d6efd;
    }
</style>
<div class="modal fade glass-modal" id="plantillaModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content border-0">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-success" id="plantillaModalTitle">Setup Plantilla</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="plantillaForm">
                <div class="modal-body pb-4">
                    <input type="hidden" id="plantillaPosId" name="id">
                    <div id="plantillaSetsContainer">
                        <div class="mb-3 border rounded p-3 plantilla-set">
                            <div class="mb-2">
                                <label class="form-label fw-semibold small text-secondary">Plantilla Item No.</label>
                                <textarea class="form-control plantilla-items-input" rows="2" placeholder="e.g. ADOF1-660031-2004, ADOF2-662546-2006"></textarea>
                            </div>
                            <div class="row g-2 mb-2">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold small text-secondary">Parenthetical Title</label>
                                    <input type="text" class="form-control plantilla-parenthetical" placeholder="e.g. Clerk I">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold small text-secondary">Place of Assignment</label>
                                    <input type="text" class="form-control plantilla-assignment" placeholder="e.g. Public Elementary School/s in Iligan City">
                                </div>
                            </div>
                            <div class="mt-2">
                                <label class="form-label fw-semibold small text-secondary">Competency/ Area of Specialization/ Residency Requirement (if applicable)</label>
                                <input type="text" class="form-control plantilla-competency" value="Self- Management, Professionalism and Ethics, Result Focus, Teamwork, Service Orientation, Innovation">
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-danger mt-2 remove-plantilla-set d-none">Remove</button>
                        </div>
                    </div>
                    <button type="button" class="btn btn-light-blue btn-sm mt-2" id="addPlantillaSetBtn">
                        <i class="bi bi-plus-circle"></i> Add more
                    </button>
                    <div class="form-text text-muted mt-2">Separate multiple item numbers with a comma. The vacancy count will be automatically calculated based on the total number of items across all sets.</div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light shadow-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary shadow-sm" id="savePlantillaBtn">
                        <i class="bi bi-save"></i> Save Setup
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
