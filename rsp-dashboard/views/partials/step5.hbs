        <!-- STEP 5 -->
        {{#if step5Active}}
            <h2 class="fw-semibold mb-3">Assignment Orders</h2>
            <p class="text-muted">Finalized pool of applicants with complete requirements. Issue and generate their official Assignment Orders here.</p>
            
            <div class="mb-3">
                
                <form method="GET" action="/step5/1" class="row g-2">
                    <div class="col-md-3">
                        <div class="input-group glass-panel h-100 shadow-sm">
                            <span class="input-group-text bg-white border-end-0 cursor-pointer" onclick="submitSearch(this.closest('form'))"><i class="bi bi-search text-primary"></i></span>
                            <input type="text" name="q" class="form-control border-start-0 ps-0" placeholder="Search by name or application code..." value="{{searchQuery}}" onkeypress="if(event.key === 'Enter') { event.preventDefault(); submitSearch(this.form); }">
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="glass-panel filter-glass-panel h-100 px-2 py-1">
                            <select name="position" class="form-select bg-transparent border-0 shadow-none custom-ui-select" onchange="if(this.form.vacancy) this.form.vacancy.value=''; if(this.form.step) this.form.step.value=''; if(this.form.remarks) this.form.remarks.value=''; if(this.form.office) this.form.office.value=''; this.form.submit()">
                                <option value="">All Positions</option>
                                {{#each positionList}}
                                    <option value="{{this}}" {{#if (eq this ../positionFilter)}}selected{{/if}}>{{this}}</option>
                                {{/each}}
                            </select>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="glass-panel filter-glass-panel h-100 px-2 py-1">
                            <select name="vacancy" class="form-select bg-transparent border-0 shadow-none custom-ui-select" onchange="this.form.submit()">
                                <option value="">All Vacancies</option>
                                {{#each vacancyList}}
                                    <option value="{{this}}" {{#if (eq this ../vacancyFilter)}}selected{{/if}}>{{this}}</option>
                                {{/each}}
                            </select>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="glass-panel filter-glass-panel dropdown-narrow-expansion h-100 px-2 py-1">
                            <select name="office" class="form-select bg-transparent border-0 shadow-none custom-ui-select" onchange="this.form.submit()">
                                <option value="">All Offices</option>
                                {{#each officeList}}
                                    <option value="{{this}}" {{#if (eq this ../officeFilter)}}selected{{/if}}>{{this}}</option>
                                {{/each}}
                            </select>
                        </div>
                    </div>
                </form>
            </div>

            <div class="rounded-3 overflow-hidden shadow-sm">
                <table class="table table-hover align-middle mb-0 custom-table" id="table-step5">
                    <thead class="table-light">
                        <tr>
                            <th>Application Code</th>
                            <th>Applicant Name</th>
                            <th>Position</th>
                            <th>Assigned Office</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each step5}}
                        <tr>
                            <td><span class="badge bg-secondary font-monospace">{{this.applicationCode}}</span></td>
                            <td class="fw-medium applicant-name-display-{{this.id}}">{{titleCase this.name}}</td>
                            <td>{{this.position}}</td>
                            <td>{{this.assignedOffice}}</td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-primary action-btn" onclick="window.openGenericDocModal(5, {{this.id}}, '', '', `{{titleCase this.name}}`, `{{this.assignedOffice}}`, `{{this.category}}`, `{{this.applicationCode}}`, `{{this.cc}}`, `{{this.ccDesignation}}`)" title="Generate DOC">
                                    <i class="bi bi-file-earmark-word"></i> DOC
                                </button>
                            </td>
                        </tr>
                        {{else}}
                        <tr><td colspan="5" class="text-center text-muted py-4">No assignment orders available.</td></tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
            
            {{#if pagination.[1]}}
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination flex-wrap justify-content-center mb-0">
                    {{#each pagination}}
                        {{#if this.isEllipsis}}
                            <li class="page-item disabled"><span class="page-link border-0 bg-transparent text-muted">...</span></li>
                        {{else}}
                            <li class="page-item {{#if this.isCurrent}}active{{/if}}">
                                <a class="page-link mx-1 {{#if this.isCurrent}}shadow-sm{{/if}} {{#if @first}}page-first{{else if @last}}page-last{{else}}rounded-circle{{/if}}" href="{{this.url}}">{{this.page}}</a>
                            </li>
                        {{/if}}
                    {{/each}}
                </ul>
            </nav>
            {{/if}}
        {{/if}}
    


