<!-- Generic Delete Confirmation Modal -->
<div class="modal fade glass-modal" id="deleteConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 bg-danger bg-opacity-10 text-danger pb-2">
                <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i> Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-4">
                <p class="mb-4 text-dark">Are you sure you want to delete this record? This action cannot be undone.</p>
                <input type="hidden" id="deleteConfirmType">
                <input type="hidden" id="deleteConfirmRecordId">
                <input type="hidden" id="deleteConfirmApplicantId">
                <input type="hidden" id="deleteConfirmModalType">
                <div class="d-flex gap-2 justify-content-center">
                    <button type="button" class="btn btn-secondary w-50" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger w-50 fw-bold" onclick="executeDeleteRecord()">Delete</button>
                </div>
            </div>
        </div>
    </div>
</div>
