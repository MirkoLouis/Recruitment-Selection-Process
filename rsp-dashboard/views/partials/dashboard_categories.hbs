        <!-- Categories Tab -->
        <div class="tab-pane fade {{#if selectedPosition}}show active{{/if}} {{#if showCategories}}show active{{/if}}" id="categories" role="tabpanel">
            <div class="glass-panel p-4 rounded-4 shadow-sm h-100 position-relative">
                
                <!-- Search & Filter -->
                <div class="mb-3">
                    <form class="row g-2" onsubmit="event.preventDefault(); filterVacancyTable();">
                        <div class="col-md-4">
                            <div class="input-group glass-panel h-100">
                                <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                                <input type="text" id="vacancySearch" class="form-control bg-transparent border-0 shadow-none" placeholder="Search position name..." onkeyup="filterVacancyTable()">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="glass-panel h-100 px-2 py-1">
                                <select id="vacancyCategory" class="form-select bg-transparent border-0 shadow-none" onchange="filterVacancyTable()">
                                    <option value="">All Categories</option>
                                    {{#each groupedPositions}}
                                        <option value="{{this.categoryName}}">{{this.categoryName}}</option>
                                    {{/each}}
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="glass-panel h-100 px-2 py-1">
                                <select id="vacancyStatus" class="form-select bg-transparent border-0 shadow-none" onchange="filterVacancyTable()">
                                    <option value="">All Statuses</option>
                                    <option value="vacant">Vacant</option>
                                    <option value="non-vacant">Non-Vacant</option>
                                </select>
                            </div>
                        </div>
                    </form>
                </div>

                <table class="table table-hover align-middle mb-0 border-light" id="vacancyTable">
                    <thead>
                        <tr>
                            <th class="fw-bold">Position Name</th>
                            <th class="text-center fw-bold">Vacancy</th>
                            <th class="text-center fw-bold">Plantilla</th>
                            <th class="text-center fw-bold">Slots</th>
                            <th class="text-center fw-bold">Position Info</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each groupedPositions}}
                            <tr class="table-light vacancy-category-group" data-category="{{this.categoryName}}">
                                <td colspan="5" class="fw-bold text-primary bg-primary bg-opacity-10 border-0">{{this.categoryName}}</td>
                            </tr>
                            {{#each this.positions}}
                            <tr class="vacancy-row" data-category="{{../this.categoryName}}" data-title="{{this.title}}">
                                <td class="fw-semibold">{{this.title}}</td>
                                <td class="text-center">
                                    <div class="form-check form-switch d-flex justify-content-center">
                                        <input class="form-check-input vacancy-toggle cursor-pointer" type="checkbox" data-id="{{this.id}}" {{#if this.in_vacancy}}checked{{/if}} style="transform: scale(1.3);">
                                    </div>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-success shadow-sm plantilla-setup-btn rounded-pill px-3" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#plantillaModal"
                                        data-id="{{this.id}}"
                                        data-title="{{this.title}}"
                                        data-count="{{this.vacancyCount}}"
                                        data-plantilla="{{this.plantillaItem}}"
                                        id="plantilla-btn-{{this.id}}"
                                        {{#unless this.in_vacancy}}disabled{{/unless}}>
                                        <i class="bi bi-list-ol me-1"></i> Setup
                                    </button>
                                </td>
                                <td class="text-center fw-bold text-secondary" id="slot-count-{{this.id}}">{{#if this.in_vacancy}}{{this.vacancyCount}}{{else}}0{{/if}}</td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-primary shadow-sm position-info-btn rounded-pill px-3" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#positionInfoModal"
                                        data-id="{{this.id}}"
                                        data-title="{{this.title}}"
                                        data-vacancy="{{this.vacancyAnnouncement}}"
                                        data-plantilla="{{this.plantillaItem}}"
                                        data-salary="{{this.salaryGrade}}"
                                        data-monthly="{{this.monthlySalary}}"
                                        data-edu="{{this.qsEducation}}"
                                        data-edu-level="{{this.qsEducationLevel}}"
                                        data-train="{{this.qsTraining}}"
                                        data-train-level="{{this.qsTrainingLevel}}"
                                        data-exp="{{this.qsExperience}}"
                                        data-exp-level="{{this.qsExperienceLevel}}"
                                        data-elig="{{this.qsEligibility}}">
                                        <i class="bi bi-info-circle me-1"></i> Info
                                    </button>
                                </td>
                            </tr>
                            {{/each}}
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>