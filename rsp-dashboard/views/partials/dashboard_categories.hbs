        <!-- Categories Tab -->
        <div class="tab-pane fade {{#if selectedPosition}}show active{{/if}} {{#if showCategories}}show active{{/if}}" id="categories" role="tabpanel">
            <div class="glass-panel p-4 rounded-4 shadow-sm h-100 position-relative">
                
                <!-- Search & Filter -->
                <div class="mb-3">
                    <form class="row g-2" onsubmit="event.preventDefault(); filterVacancyTable();">
                        <div class="col-md-3">
                            <div class="input-group glass-panel h-100">
                                <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-muted"></i></span>
                                <input type="text" id="vacancySearch" class="form-control bg-transparent border-0 shadow-none" placeholder="Search position name..." onkeyup="filterVacancyTable()">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="glass-panel h-100 px-2 py-1">
                                <select id="vacancyCategory" class="form-select bg-transparent border-0 shadow-none" onchange="filterVacancyTable()">
                                    <option value="">All Categories</option>
                                    {{#each groupedPositions}}
                                        <option value="{{this.categoryName}}">{{this.categoryName}}</option>
                                    {{/each}}
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="glass-panel h-100 px-2 py-1">
                                <select id="vacancyStatus" class="form-select bg-transparent border-0 shadow-none" onchange="filterVacancyTable()">
                                    <option value="">All Statuses</option>
                                    <option value="vacant">Vacant</option>
                                    <option value="non-vacant">Non-Vacant</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <button type="button" class="btn btn-primary h-100 w-100 fw-bold shadow-sm rounded-3" data-bs-toggle="modal" data-bs-target="#addPositionModal">
                                <i class="bi bi-plus-circle-fill me-2"></i> Add Position
                            </button>
                        </div>
                    </form>
                </div>

                <div id="vacancyWizardLayout">
                    <!-- Step 0: Category Grid -->
                    <div id="vacancyCategorySelection">
                        <div class="row g-4">
                            {{#each groupedPositions}}
                            <div class="col-md-6 vacancy-category-grid-item" data-category="{{this.categoryName}}">
                                <button type="button" class="btn btn-outline-primary category-btn-hover w-100 py-4 fw-bold rounded-4 shadow-sm bg-white" onclick="showVacancyCategory('{{this.categorySlug}}', '{{this.categoryName}}')">
                                    <i class="bi bi-folder-fill fs-1 d-block mb-2"></i>
                                    <span class="fs-5">{{this.categoryName}}</span>
                                </button>
                            </div>
                            {{/each}}
                        </div>
                    </div>

                    <!-- Step 1: Positions View -->
                    <div id="vacancyPositionContent" class="d-none">
                        <div class="d-flex align-items-center mb-4">
                            <button type="button" class="btn btn-light shadow-sm me-3 rounded-circle" onclick="showVacancyCategorySelection()" style="width: 45px; height: 45px;">
                                <i class="bi bi-arrow-left fs-5"></i>
                            </button>
                            <h4 class="mb-0 fw-bold text-primary" id="activeCategoryTitle">Category Name</h4>
                        </div>

                        <div class="tab-content" id="v-pills-tabContent">
                            {{#each groupedPositions}}
                                <div class="tab-pane fade vacancy-category-group" id="v-pills-{{this.categorySlug}}" role="tabpanel" data-category="{{this.categoryName}}" data-bs-target="#v-pills-{{this.categorySlug}}">
                                    <div class="bg-white p-3 rounded-4 shadow-sm border-0">
                                        <div class="accordion" id="accordionGroup-{{this.categorySlug}}">
                                            {{#each this.positionGroups}}
                                                <div class="accordion-item border mb-2 rounded-3 vacancy-group-wrapper" data-category="{{../this.categoryName}}" data-group="{{this.groupName}}" style="overflow: hidden;">
                                                    <h2 class="accordion-header" id="heading-{{../this.categorySlug}}-{{this.groupSlug}}">
                                                        <button class="accordion-button collapsed fw-semibold text-secondary py-2 bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-{{../this.categorySlug}}-{{this.groupSlug}}" aria-expanded="false" aria-controls="collapse-{{../this.categorySlug}}-{{this.groupSlug}}">
                                                            <i class="bi bi-journal-text me-2"></i> {{this.groupName}}
                                                        </button>
                                                    </h2>
                                                    <div id="collapse-{{../this.categorySlug}}-{{this.groupSlug}}" class="accordion-collapse collapse" aria-labelledby="heading-{{../this.categorySlug}}-{{this.groupSlug}}" data-bs-parent="#accordionGroup-{{../this.categorySlug}}">
                                                        <div class="accordion-body p-0">
                                                            <div class="table-responsive">
                                                                <table class="table table-hover align-middle mb-0 border-0 vacancyTable">
                                                                    <thead class="table-light border-bottom">
                                                                        <tr>
                                                                            <th class="fw-bold px-3">Position Name</th>
                                                                            <th class="text-center fw-bold">Vacancy</th>
                                                                            <th class="text-center fw-bold">Plantilla</th>
                                                                            <th class="text-center fw-bold">Slots</th>
                                                                            <th class="text-center fw-bold">Position Info</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        {{#each this.positions}}
                                                                        <tr class="vacancy-row" data-category="{{../../this.categoryName}}" data-title="{{this.title}}" data-group="{{../this.groupName}}">
                                                                            <td class="fw-semibold px-3">{{this.title}}</td>
                                                                            <td class="text-center">
                                                                                <div class="form-check form-switch d-flex justify-content-center">
                                                                                    <input class="form-check-input vacancy-toggle cursor-pointer" type="checkbox" data-id="{{this.id}}" {{#if this.in_vacancy}}checked{{/if}} style="transform: scale(1.3);">
                                                                                </div>
                                                                            </td>
                                                                            <td class="text-center">
                                                                                <button class="btn btn-sm btn-outline-success shadow-sm plantilla-setup-btn rounded-pill px-3" 
                                                                                    data-bs-toggle="modal" 
                                                                                    data-bs-target="#plantillaModal"
                                                                                    data-id="{{this.id}}"
                                                                                    data-title="{{this.title}}"
                                                                                    data-count="{{this.vacancyCount}}"
                                                                                    data-plantilla="{{this.plantillaItem}}"
                                                                                    id="plantilla-btn-{{this.id}}"
                                                                                    {{#unless this.in_vacancy}}disabled{{/unless}}>
                                                                                    <i class="bi bi-list-ol me-1"></i> Setup
                                                                                </button>
                                                                            </td>
                                                                            <td class="text-center fw-bold text-secondary" id="slot-count-{{this.id}}">{{#if this.in_vacancy}}{{this.vacancyCount}}{{else}}0{{/if}}</td>
                                                                            <td class="text-center">
                                                                                <button class="btn btn-sm btn-outline-primary shadow-sm position-info-btn rounded-pill px-3" 
                                                                                    data-bs-toggle="modal" 
                                                                                    data-bs-target="#positionInfoModal"
                                                                                    data-id="{{this.id}}"
                                                                                    data-title="{{this.title}}"
                                                                                    data-vacancy="{{this.vacancyAnnouncement}}"
                                                                                    data-plantilla="{{this.plantillaItem}}"
                                                                                    data-salary="{{this.salaryGrade}}"
                                                                                    data-monthly="{{this.monthlySalary}}"
                                                                                    data-edu="{{this.qsEducation}}"
                                                                                    data-edu-level="{{this.qsEducationLevel}}"
                                                                                    data-train="{{this.qsTraining}}"
                                                                                    data-train-level="{{this.qsTrainingLevel}}"
                                                                                    data-exp="{{this.qsExperience}}"
                                                                                    data-exp-level="{{this.qsExperienceLevel}}"
                                                                                    data-elig="{{this.qsEligibility}}">
                                                                                    <i class="bi bi-info-circle me-1"></i> Info
                                                                                </button>
                                                                            </td>
                                                                        </tr>
                                                                        {{/each}}
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            {{/each}}
                                        </div>
                                        <div class="w-100 mt-3" id="pagination-{{this.categorySlug}}">
                                            <!-- Pagination populated by PaginationHelper -->
                                        </div>
                                    </div>
                                </div>
                            {{/each}}
                        </div>
                    </div>
                </div>

                <script>
                    function showVacancyCategory(slug, title) {
                        document.getElementById('vacancyCategorySelection').classList.add('d-none');
                        document.getElementById('vacancyPositionContent').classList.remove('d-none');
                        document.getElementById('activeCategoryTitle').innerText = title;
                        
                        // Hide all panes
                        document.querySelectorAll('#v-pills-tabContent .tab-pane').forEach(pane => {
                            pane.classList.remove('show', 'active');
                        });
                        
                        // Show selected pane
                        const targetPane = document.getElementById('v-pills-' + slug);
                        if (targetPane) {
                            targetPane.classList.add('show', 'active');
                        }
                    }

                    function showVacancyCategorySelection() {
                        document.getElementById('vacancyPositionContent').classList.add('d-none');
                        document.getElementById('vacancyCategorySelection').classList.remove('d-none');
                    }
                </script>
            </div>
        </div>
