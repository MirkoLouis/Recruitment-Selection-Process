        <!-- Categories Tab -->
        <style>
            .sidebar-scroll {
                max-height: 65vh;
                overflow-y: auto;
                padding-right: 5px;
            }
            .sidebar-scroll::-webkit-scrollbar {
                width: 6px;
            }
            .sidebar-scroll::-webkit-scrollbar-track {
                background: #f1f1f1;
                border-radius: 10px;
            }
            .sidebar-scroll::-webkit-scrollbar-thumb {
                background: #c1c1c1;
                border-radius: 10px;
            }
            .sidebar-scroll::-webkit-scrollbar-thumb:hover {
                background: #a8a8a8;
            }
            .search-hidden-row {
                display: none !important;
            }
            .search-hidden {
                display: none !important;
            }
        </style>
        <div class="tab-pane fade {{#if selectedPosition}}show active{{/if}} {{#if showCategories}}show active{{/if}}" id="categories" role="tabpanel">
            <div class="glass-panel p-4 rounded-4 shadow-sm h-100 position-relative">
                
                <!-- Search & Filter -->
                <div class="mb-3">
                    <form class="row g-2" onsubmit="event.preventDefault(); filterVacancyTable();">
                        <div class="col-md-3">
                            <div class="input-group glass-panel h-100 shadow-sm">
                                <span class="input-group-text bg-white border-end-0 cursor-pointer" onclick="filterVacancyTable()"><i class="bi bi-search text-primary"></i></span>
                                <input type="text" id="vacancySearch" class="form-control border-start-0 ps-0" placeholder="Search position name..." onkeydown="if(event.key === 'Enter') { event.preventDefault(); filterVacancyTable(); }">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="glass-panel filter-glass-panel h-100 px-2 py-1">
                                <select id="vacancyCategory" class="form-select bg-transparent border-0 shadow-none custom-ui-select" onchange="filterVacancyTable()">
                                    <option value="">All Categories</option>
                                    {{#each groupedPositions}}
                                        <option value="{{this.categoryName}}">{{this.categoryName}}</option>
                                    {{/each}}
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="glass-panel filter-glass-panel h-100 px-2 py-1">
                                <select id="vacancyStatus" class="form-select bg-transparent border-0 shadow-none custom-ui-select" onchange="filterVacancyTable()">
                                    <option value="">All Statuses</option>
                                    <option value="vacant">Vacant</option>
                                    <option value="non-vacant">Non-Vacant</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4 d-flex gap-2">
                            <button type="button" class="btn btn-primary h-100 w-50 fw-bold shadow-sm rounded-3" data-bs-toggle="modal" data-bs-target="#addPositionModal">
                                <i class="bi bi-plus-circle-fill me-1"></i> Add Position
                            </button>
                            <button type="button" id="offAllVacancyBtn" class="btn btn-danger h-100 w-50 fw-bold shadow-sm rounded-3">
                                <i class="bi bi-power me-1"></i> Off Vacancy
                            </button>
                        </div>
                    </form>
                </div>

                <div id="vacancyWizardLayout">
                    <div id="vacancyEmptyState" class="d-none text-center p-5 text-muted mt-4 glass-panel rounded-4">
                        <i class="bi bi-search fs-1 d-block mb-2 opacity-50"></i>
                        <h5 class="fw-semibold">No positions found</h5>
                        <p class="mb-0 small opacity-75">Try adjusting your search filters.</p>
                    </div>
                    <!-- Step 0: Category Grid -->
                    <div id="vacancyCategorySelection">
                        <div class="row g-4">
                            {{#each groupedPositions}}
                            <div class="col-md-6 vacancy-category-grid-item" data-category="{{this.categoryName}}">
                                <button type="button" class="btn btn-outline-primary category-btn-hover w-100 py-4 fw-bold rounded-4 shadow-sm bg-white" onclick="showVacancyCategory('{{this.categorySlug}}', '{{this.categoryName}}')">
                                    <i class="bi bi-folder-fill fs-1 d-block mb-2"></i>
                                    <span class="fs-5">{{this.categoryName}}</span>
                                </button>
                            </div>
                            {{/each}}
                        </div>
                    </div>

                    <!-- Step 1: Positions View -->
                    <div id="vacancyPositionContent" class="d-none">
                        <div class="d-flex align-items-center mb-4">
                            <button type="button" class="btn btn-light shadow-sm me-3 rounded-circle" onclick="showVacancyCategorySelection()" style="width: 45px; height: 45px;">
                                <i class="bi bi-arrow-left fs-5"></i>
                            </button>
                            <h4 class="mb-0 fw-bold text-primary" id="activeCategoryTitle">Category Name</h4>
                        </div>

                        <div class="tab-content" id="v-pills-tabContent">
                            {{#each groupedPositions}}
                                <div class="tab-pane fade vacancy-category-group" id="v-pills-{{this.categorySlug}}" role="tabpanel" data-category="{{this.categoryName}}" data-bs-target="#v-pills-{{this.categorySlug}}">
                                    <div class="bg-white p-4 rounded-4 shadow-sm border-0">
                                        <div class="row min-vh-50">
                                            <!-- Vertical Sidebar for Groups -->
                                            <div class="col-md-3 border-end pe-3">
                                                <h6 class="text-uppercase fw-bold text-muted mb-3 fs-7" style="letter-spacing: 1px;">Position Groups</h6>
                                                <div class="nav flex-column nav-pills gap-1 sidebar-scroll" id="v-pills-group-{{this.categorySlug}}" role="tablist" aria-orientation="vertical">
                                                    {{#each this.positionGroups}}
                                                        <button class="nav-link text-start fw-semibold vacancy-group-tab-btn {{#if @first}}active{{/if}} rounded-3" 
                                                                id="tab-btn-{{../this.categorySlug}}-{{this.groupSlug}}" 
                                                                data-bs-toggle="pill" 
                                                                data-bs-target="#tab-pane-{{../this.categorySlug}}-{{this.groupSlug}}" 
                                                                type="button" role="tab"
                                                                data-category="{{../this.categoryName}}" data-group="{{this.groupName}}"
                                                                style="transition: all 0.2s;">
                                                            <i class="bi bi-folder2 me-2 opacity-75"></i> {{this.groupName}}
                                                        </button>
                                                    {{/each}}
                                                </div>
                                            </div>
                                            <!-- Main Content Area for Table -->
                                            <div class="col-md-9 ps-4">
                                                <div class="tab-content" id="v-pills-group-tabContent-{{this.categorySlug}}">
                                                    {{#each this.positionGroups}}
                                                        <div class="tab-pane fade {{#if @first}}show active{{/if}} vacancy-group-wrapper" 
                                                             id="tab-pane-{{../this.categorySlug}}-{{this.groupSlug}}" 
                                                             role="tabpanel"
                                                             data-category="{{../this.categoryName}}" data-group="{{this.groupName}}">
                                                            
                                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                                <h5 class="fw-bold text-secondary mb-0"><i class="bi bi-journal-text me-2"></i>{{this.groupName}}</h5>
                                                            </div>
                                                            <div class="table-responsive border rounded-3">
                                                                <table class="table table-hover align-middle mb-0 border-0 vacancyTable">
                                                                    <thead class="table-light border-bottom">
                                                                        <tr>
                                                                            <th class="fw-bold px-3 py-3">Position Name</th>
                                                                            <th class="text-center fw-bold py-3">Vacancy</th>
                                                                            <th class="text-center fw-bold py-3">Plantilla</th>
                                                                            <th class="text-center fw-bold py-3">Slots</th>
                                                                            <th class="text-center fw-bold py-3">Position Info</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        {{#each this.positions}}
                                                                        <tr class="vacancy-row" data-category="{{../../this.categoryName}}" data-title="{{this.title}}" data-group="{{../this.groupName}}">
                                                                            <td class="fw-semibold px-3">{{this.title}}</td>
                                                                            <td class="text-center">
                                                                                <div class="form-check form-switch d-flex justify-content-center">
                                                                                    <input class="form-check-input vacancy-toggle cursor-pointer" type="checkbox" data-id="{{this.id}}" {{#if this.in_vacancy}}checked{{/if}} style="transform: scale(1.3);">
                                                                                </div>
                                                                            </td>
                                                                            <td class="text-center">
                                                                                <button class="btn btn-sm btn-outline-success shadow-sm plantilla-setup-btn rounded-pill px-3" 
                                                                                    data-bs-toggle="modal" 
                                                                                    data-bs-target="#plantillaModal"
                                                                                    data-id="{{this.id}}"
                                                                                    data-title="{{this.title}}"
                                                                                    data-count="{{this.vacancyCount}}"
                                                                                    data-plantilla="{{this.plantillaItem}}"
                                                                                    id="plantilla-btn-{{this.id}}"
                                                                                    {{#unless this.in_vacancy}}disabled{{/unless}}>
                                                                                    <i class="bi bi-list-ol me-1"></i> Setup
                                                                                </button>
                                                                            </td>
                                                                            <td class="text-center fw-bold text-secondary" id="slot-count-{{this.id}}">{{#if this.in_vacancy}}{{this.vacancyCount}}{{else}}0{{/if}}</td>
                                                                            <td class="text-center">
                                                                                <button class="btn btn-sm btn-outline-primary shadow-sm position-info-btn rounded-pill px-3" 
                                                                                    data-bs-toggle="modal" 
                                                                                    data-bs-target="#positionInfoModal"
                                                                                    data-id="{{this.id}}"
                                                                                    data-title="{{this.title}}"
                                                                                    data-vacancy="{{this.vacancyAnnouncementNo}}"
                                                                                    data-plantilla="{{this.plantillaItem}}"
                                                                                    data-salary="{{this.salaryGrade}}"
                                                                                    data-monthly="{{this.monthlySalary}}"
                                                                                    data-edu="{{this.qsEducation}}"
                                                                                    data-edu-level="{{this.qsEducationLevel}}"
                                                                                    data-train="{{this.qsTraining}}"
                                                                                    data-train-level="{{this.qsTrainingLevel}}"
                                                                                    data-exp="{{this.qsExperience}}"
                                                                                    data-exp-level="{{this.qsExperienceLevel}}"
                                                                                    data-elig="{{this.qsEligibility}}">
                                                                                    <i class="bi bi-info-circle me-1"></i> Info
                                                                                </button>
                                                                            </td>
                                                                        </tr>
                                                                        {{/each}}
                                                                    </tbody>
                                                                </table>
                                                            </div>
                                                            <div class="w-100 mt-2" id="pagination-tab-pane-{{../this.categorySlug}}-{{this.groupSlug}}"></div>
                                                        </div>
                                                    {{/each}}
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {{/each}}
                        </div>
                    </div>
                </div>

                <script>
                    function showVacancyCategory(slug, title) {
                        document.getElementById('vacancyCategorySelection').classList.add('d-none');
                        document.getElementById('vacancyPositionContent').classList.remove('d-none');
                        document.getElementById('activeCategoryTitle').innerText = title;
                        
                        // Hide all category panes
                        document.querySelectorAll('.vacancy-category-group').forEach(pane => {
                            pane.classList.remove('show', 'active');
                        });
                        
                        // Show selected pane
                        const targetPane = document.getElementById('v-pills-' + slug);
                        if (targetPane) {
                            targetPane.classList.add('show', 'active');
                        }
                    }

                    function showVacancyCategorySelection() {
                        document.getElementById('vacancyPositionContent').classList.add('d-none');
                        document.getElementById('vacancyCategorySelection').classList.remove('d-none');
                    }
                </script>
            </div>
        </div>
