<!-- CAR Download Modal -->
<div class="modal fade" id="carDownloadModal" tabindex="-1" aria-labelledby="carDownloadModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold" id="carDownloadModalLabel">Download CAR</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center pt-2 pb-4">
                <p class="text-muted mb-4">Choose how you want to export the Comparative Assessment Result.</p>
                <div class="d-grid gap-3">
                    <button type="button" class="btn btn-outline-primary fw-bold" onclick="downloadCAR('withName')">
                        <i class="bi bi-person-lines-fill me-2"></i> With Name
                    </button>

                    <button type="button" class="btn btn-outline-secondary fw-bold" onclick="downloadCAR('withoutName')">
                        <i class="bi bi-file-earmark-person me-2"></i> Without Name
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function handleCARDownloadClick() {
    const positionFilter = document.querySelector('select[name="position"]').value;
    const vacancyFilter = document.querySelector('select[name="vacancy"]').value;
    if (!positionFilter || !vacancyFilter) {
        window.showToast('Please select both Position and Vacancy filters to download the report.', 'danger');
        return;
    }
    const modal = new bootstrap.Modal(document.getElementById('carDownloadModal'));
    modal.show();
}

function downloadCAR(exportType) {
    const positionFilter = document.querySelector('select[name="position"]').value;
    let url = '/api/export/car?';
    url += 'position=' + encodeURIComponent(positionFilter) + '&';
    url += 'exportType=' + exportType;
    window.showToast("Spreadsheet generated successfully.", "success");
    window.location.href = url;
    const modalEl = document.getElementById('carDownloadModal');
    const modal = bootstrap.Modal.getInstance(modalEl);
    if (modal) {
        modal.hide();
    }
}
</script>
