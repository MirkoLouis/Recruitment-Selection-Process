<!-- IER Download Modal -->
<div class="modal fade" id="ierDownloadModal" tabindex="-1" aria-labelledby="ierDownloadModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold" id="ierDownloadModalLabel">Download IER</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center pt-2 pb-4">
                <p class="text-muted mb-4">Choose how you want to export the Initial Evaluation Result.</p>
                <div class="d-grid gap-3">
                    <button type="button" class="btn btn-outline-primary fw-bold" onclick="downloadIER('withName')">
                        <i class="bi bi-person-lines-fill me-2"></i> With Name
                    </button>
                    <button type="button" class="btn btn-outline-info fw-bold" onclick="downloadIER('withDetails')" disabled>
                        <i class="bi bi-card-text me-2"></i> With Personal Details (Coming Soon)
                    </button>
                    <button type="button" class="btn btn-outline-secondary fw-bold" onclick="downloadIER('withoutName')">
                        <i class="bi bi-file-earmark-person me-2"></i> Without Name
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function downloadIER(exportType) {
    const positionFilter = document.querySelector('select[name="position"]').value;
    let url = '/api/export/ier?';
    if (positionFilter) {
        url += 'position=' + encodeURIComponent(positionFilter) + '&';
    }
    url += 'exportType=' + exportType;
    window.location.href = url;
    bootstrap.Modal.getInstance(document.getElementById('ierDownloadModal')).hide();
}
</script>
