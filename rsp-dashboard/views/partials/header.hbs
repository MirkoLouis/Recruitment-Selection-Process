<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RSP Dashboard</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body>
    <nav class="navbar navbar-dark premium-nav sticky-top">
        <div class="container-fluid d-flex justify-content-between align-items-center">
            <!-- Left Side: Brand -->
            <a class="navbar-brand d-flex align-items-center gap-2 m-0" href="/">
                <i class="bi bi-briefcase text-primary fs-3"></i>
                <span class="fw-bold">RSP Dashboard</span>
            </a>
            
            <!-- Center: Nav Tabs -->
            <ul class="nav nav-pills custom-tabs m-0" id="rspTab" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="step1-tab" data-bs-toggle="tab" data-bs-target="#step1" type="button" role="tab">Step 1: Notice of Requirements</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="step2-tab" data-bs-toggle="tab" data-bs-target="#step2" type="button" role="tab">Step 2: Deliberation Sheet</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="step3-tab" data-bs-toggle="tab" data-bs-target="#step3" type="button" role="tab">Step 3: Comparative Assessments</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="step4-tab" data-bs-toggle="tab" data-bs-target="#step4" type="button" role="tab">Step 4: Assignment Orders</button>
                </li>
            </ul>

            <!-- Right Side: Invisible Spacer identical to brand to force exact center -->
            <div class="navbar-brand d-flex align-items-center gap-2 m-0" style="visibility: hidden;" aria-hidden="true">
                <i class="bi bi-layers-half fs-3"></i>
                <span class="fw-bold">RSP Dashboard</span>
            </div>
        </div>
    </nav>
    <main class="container py-5 main-content">
