<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RSP Dashboard</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap CSS -->
    <link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="/bootstrap-icons/bootstrap-icons.css">
</head>
<body>
    <div class="d-flex" style="min-height: 100vh;">
        <!-- Sidebar -->
        <nav class="sidebar premium-nav text-white d-flex flex-column p-4 flex-shrink-0 shadow-lg" style="width: 280px; z-index: 1000;">
            <a href="/" class="d-flex align-items-center mb-4 text-white text-decoration-none">
                <i class="bi bi-briefcase-fill text-primary fs-2 me-3"></i>
                <span class="fs-4 fw-bold">RSP Dashboard</span>
            </a>
            
            <ul class="nav nav-pills flex-column mb-auto custom-sidebar-tabs gap-2" id="rspTab">
                <li class="nav-item">
                    <a href="/step1/1" class="nav-link text-white w-100 text-start p-3 rounded-3 {{#if step1Active}}active{{/if}}">
                        <i class="bi bi-person-vcard fs-5 me-2 align-middle"></i> <span class="align-middle">Step 1: Evaluation</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/step2/1" class="nav-link text-white w-100 text-start p-3 rounded-3 {{#if step2Active}}active{{/if}}">
                        <i class="bi bi-chat-square-text fs-5 me-2 align-middle"></i> <span class="align-middle">Step 2: Deliberation</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/step3/1" class="nav-link text-white w-100 text-start p-3 rounded-3 {{#if step3Active}}active{{/if}}">
                        <i class="bi bi-bar-chart-steps fs-5 me-2 align-middle"></i> <span class="align-middle">Step 3: Assessments</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/step4/1" class="nav-link text-white w-100 text-start p-3 rounded-3 {{#if step4Active}}active{{/if}}">
                        <i class="bi bi-card-checklist fs-5 me-2 align-middle"></i> <span class="align-middle">Step 4: Requirements</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/step5/1" class="nav-link text-white w-100 text-start p-3 rounded-3 {{#if step5Active}}active{{/if}}">
                        <i class="bi bi-envelope-paper fs-5 me-2 align-middle"></i> <span class="align-middle">Step 5: Assignments</span>
                    </a>
                </li>
            </ul>
        </nav>
        
        <!-- Main Content Wrapper -->
        <main class="flex-grow-1 p-5 main-content" style="height: 100vh; overflow-y: auto; background-color: #f8fafc;">
            <div class="container-fluid max-w-1200 mx-auto">
