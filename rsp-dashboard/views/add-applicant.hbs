{{> header}}

<div class="glass-panel p-4 mb-0 shadow-sm rounded-4 d-print-none">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h2 class="fw-semibold text-primary mb-0" id="addApplicantTitle"><i class="bi bi-person-plus-fill me-2"></i>New Applicant Wizard</h2>
    </div>
    
    <form id="addApplicantForm">
                <!-- Step 0: Category & Position -->
                <div id="wizardStep0">
                    <h6 id="categorySelectionTitle" class="mb-4 text-center fw-bold text-secondary">Select Applicant Category</h6>
                    <div class="row g-3 mb-4" id="categorySelection">
                        {{#each groupedPositions}}
                        <div class="col-sm-6 col-md-3">
                            <button type="button" class="btn btn-outline-primary w-100 py-3 fw-semibold category-btn" data-category="{{this.categoryName}}" style="transition: all 0.3s ease;">
                                {{this.categoryName}}
                            </button>
                        </div>
                        {{/each}}
                    </div>
                    
                    <div id="positionSelection" class="d-none mt-5">
                        <div class="d-flex justify-content-between align-items-center mb-4 mx-auto" style="max-width: 800px;">
                            <h5 class="mb-0 fw-bold text-primary border-bottom border-2 border-primary pb-2 px-3" id="selectedCategoryTitle">Select Position</h5>
                            <div class="input-group shadow-sm" style="width: 250px;">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                                <input type="text" class="form-control border-start-0 ps-0" id="positionSearch" placeholder="Search positions..." oninput="filterAndPaginatePositions(1)">
                            </div>
                        </div>
                        <div class="list-group border rounded-4 shadow-sm mx-auto overflow-hidden" id="positionList" style="max-width: 800px;">
                            <!-- Populated via JS -->
                        </div>
                        <div class="d-flex justify-content-center mt-4">
                            <ul class="pagination pagination-sm shadow-sm" id="positionPagination">
                                <!-- Populated via JS -->
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Step 1: Personal Info -->
                <div id="wizardStep1" class="d-none">
                    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                        <button type="button" class="btn btn-sm btn-light me-3 border shadow-sm" onclick="backToPositions()"><i class="bi bi-arrow-left"></i> Back</button>
                        <div>
                            <h5 class="mb-0 fw-bold text-primary">Personal Information</h5>
                            <small class="text-muted" id="selectedPositionText"></small>
                        </div>
                    </div>
                    
                    <input type="hidden" name="category" id="wizardCategory">
                    <input type="hidden" name="position" id="wizardPosition">
                    
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">First Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="firstName" required placeholder="e.g. John">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Middle Name</label>
                            <input type="text" class="form-control" name="middleName" placeholder="e.g. Smith">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Last Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="lastName" required placeholder="e.g. Doe">
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-semibold">Address</label>
                            <input type="text" class="form-control" name="address" placeholder="Complete address">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Age</label>
                            <input type="number" class="form-control" name="age" min="18">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Sex</label>
                            <select class="form-select" name="sex">
                                <option value="">Select...</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Civil Status</label>
                            <select class="form-select" name="civilStatus">
                                <option value="">Select...</option>
                                <option value="Single">Single</option>
                                <option value="Married">Married</option>
                                <option value="Widowed">Widowed</option>
                                <option value="Separated">Separated</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Religion</label>
                            <input type="text" class="form-control" name="religion">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Disability</label>
                            <input type="text" class="form-control" name="disability" placeholder="N/A if none">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Ethnic Group</label>
                            <input type="text" class="form-control" name="ethnicGroup">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Email Address</label>
                            <input type="email" class="form-control" name="emailAddress" placeholder="email@example.com">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Contact No.</label>
                            <input type="text" class="form-control" name="contactNo" placeholder="09XX XXX XXXX">
                        </div>
                    </div>
                    <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                        <button type="button" class="btn btn-primary px-4 fw-bold shadow-sm" onclick="nextStep(2)">Next <i class="bi bi-arrow-right-circle ms-2"></i></button>
                    </div>
                </div>

                <!-- Step 2: Educational Background -->
                <div id="wizardStep2" class="d-none">
                    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                        <button type="button" class="btn btn-sm btn-light me-3 border shadow-sm" onclick="prevStep(1)"><i class="bi bi-arrow-left"></i> Back</button>
                        <div>
                            <h5 class="mb-0 fw-bold text-primary">Educational Background</h5>
                            <small class="text-muted">Enter highest or most relevant education (Optional)</small>
                        </div>
                    </div>
                    <div class="row g-3 align-items-end">
                        <div class="col-md-5">
                            <label class="form-label fw-semibold">Degree / Course</label>
                            <input type="text" class="form-control" id="edu_degree" placeholder="e.g. BS Computer Science">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Year Graduated</label>
                            <input type="number" class="form-control" id="edu_year" placeholder="e.g. 2020">
                        </div>
                        <div class="col-md-1">
                            <button type="button" class="btn btn-success w-100" id="btn-add-edu"><i class="bi bi-plus-lg"></i></button>
                        </div>
                    </div>
                    <div class="mt-3" id="eduList"></div>
                    <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                        <button type="button" class="btn btn-primary px-4 fw-bold shadow-sm" onclick="nextStep(3)">Next <i class="bi bi-arrow-right-circle ms-2"></i></button>
                    </div>
                </div>

                <!-- Step 3: Training Background -->
                <div id="wizardStep3" class="d-none">
                    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                        <button type="button" class="btn btn-sm btn-light me-3 border shadow-sm" onclick="prevStep(2)"><i class="bi bi-arrow-left"></i> Back</button>
                        <div>
                            <h5 class="mb-0 fw-bold text-primary">Training Background</h5>
                            <small class="text-muted">Enter most relevant training (Optional)</small>
                        </div>
                    </div>
                    <div class="row g-3 align-items-end">
                        <div class="col-md-5">
                            <label class="form-label fw-semibold">Title of Training</label>
                            <input type="text" class="form-control" id="train_title" placeholder="e.g. Leadership Seminar">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Number of Hours</label>
                            <input type="number" class="form-control" id="train_hours" placeholder="e.g. 40">
                        </div>
                        <div class="col-md-1">
                            <button type="button" class="btn btn-success w-100" id="btn-add-train"><i class="bi bi-plus-lg"></i></button>
                        </div>
                    </div>
                    <div class="mt-3" id="trainList"></div>
                    <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                        <button type="button" class="btn btn-primary px-4 fw-bold shadow-sm" onclick="nextStep(4)">Next <i class="bi bi-arrow-right-circle ms-2"></i></button>
                    </div>
                </div>

                <!-- Step 4: Experience Background -->
                <div id="wizardStep4" class="d-none">
                    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                        <button type="button" class="btn btn-sm btn-light me-3 border shadow-sm" onclick="prevStep(3)"><i class="bi bi-arrow-left"></i> Back</button>
                        <div>
                            <h5 class="mb-0 fw-bold text-primary">Experience Background</h5>
                            <small class="text-muted">Enter most relevant experience (Optional)</small>
                        </div>
                    </div>
                    <div class="row g-3 align-items-end">
                        <div class="col-md-5">
                            <label class="form-label fw-semibold">Experience Details (Company & Role)</label>
                            <input type="text" class="form-control" id="exp_details" placeholder="e.g. Software Engineer at Tech Corp">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Number of Years</label>
                            <input type="number" class="form-control" id="exp_years" step="0.1" placeholder="e.g. 2.5">
                        </div>
                        <div class="col-md-1">
                            <button type="button" class="btn btn-success w-100" id="btn-add-exp"><i class="bi bi-plus-lg"></i></button>
                        </div>
                    </div>
                    <div class="mt-3" id="expList"></div>
                    <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                        <button type="button" class="btn btn-primary px-4 fw-bold shadow-sm" onclick="nextStep(5)">Next <i class="bi bi-arrow-right-circle ms-2"></i></button>
                    </div>
                </div>

                <!-- Step 5: Eligibility Background -->
                <div id="wizardStep5" class="d-none">
                    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                        <button type="button" class="btn btn-sm btn-light me-3 border shadow-sm" onclick="prevStep(4)"><i class="bi bi-arrow-left"></i> Back</button>
                        <div>
                            <h5 class="mb-0 fw-bold text-primary">Eligibility Background</h5>
                            <small class="text-muted">Enter most relevant eligibility (Optional)</small>
                        </div>
                    </div>
                    <div class="row g-3 align-items-end">
                        <div class="col-md-5">
                            <label class="form-label fw-semibold">Eligibility Details</label>
                            <input type="text" class="form-control" id="elig_details" placeholder="e.g. Civil Service Professional">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Rating</label>
                            <input type="text" class="form-control" id="elig_rating" placeholder="e.g. 85.5%">
                        </div>
                        <div class="col-md-1">
                            <button type="button" class="btn btn-success w-100" id="btn-add-elig"><i class="bi bi-plus-lg"></i></button>
                        </div>
                    </div>
                    <div class="mt-3" id="eligList"></div>
                    <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">Save Applicant <i class="bi bi-check-circle ms-2"></i></button>
                    </div>
                </div>
            </form>
</div>

<script>
    // Make positions map available to frontend
    const positionsByCategory = {
        {{#each groupedPositions}}
        "{{this.categoryName}}": [
            {{#each this.positions}}
            "{{this.title}}",
            {{/each}}
        ]{{#unless @last}},{{/unless}}
        {{/each}}
    };

    let currentWizardCategory = '';
    let currentPositions = [];
    let currentPage = 1;
    const itemsPerPage = 10;

    document.querySelectorAll('.category-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            selectCategory(e.target.getAttribute('data-category'));
        });
    });

    function selectCategory(cat) {
        currentWizardCategory = cat;
        document.getElementById('positionSelection').classList.remove('d-none');
        document.getElementById('selectedCategoryTitle').innerText = `${cat} Positions`;
        document.getElementById('categorySelectionTitle').classList.add('d-none');
        
        document.querySelectorAll('.category-btn').forEach(btn => {
            if (btn.getAttribute('data-category') === cat) {
                btn.classList.remove('btn-outline-primary');
                btn.classList.add('btn-primary', 'shadow');
            } else {
                btn.classList.remove('btn-primary', 'shadow');
                btn.classList.add('btn-outline-primary');
            }
        });
        
        document.getElementById('positionSearch').value = '';
        currentPositions = positionsByCategory[cat] || [];
        filterAndPaginatePositions(1);
    }

    function filterAndPaginatePositions(page = 1) {
        currentPage = page;
        const searchQuery = document.getElementById('positionSearch').value.toLowerCase();
        
        const filteredPositions = currentPositions.filter(pos => pos.toLowerCase().includes(searchQuery));
        const totalPages = Math.ceil(filteredPositions.length / itemsPerPage);
        
        if (currentPage > totalPages && totalPages > 0) currentPage = totalPages;
        
        const startIndex = (currentPage - 1) * itemsPerPage;
        const paginatedPositions = filteredPositions.slice(startIndex, startIndex + itemsPerPage);
        
        const list = document.getElementById('positionList');
        list.innerHTML = '';
        
        if (filteredPositions.length === 0) {
            list.innerHTML = '<div class="p-4 text-muted text-center fs-6 bg-light">No positions found.</div>';
            renderPagination(0);
            return;
        }

        paginatedPositions.forEach(pos => {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'list-group-item list-group-item-action py-2 px-4 d-flex justify-content-between align-items-center border-bottom';
            btn.innerHTML = `<span class="fw-semibold text-dark" style="font-size: 0.95rem;">${pos}</span> <i class="bi bi-chevron-right text-primary small"></i>`;
            btn.onclick = () => selectPosition(currentWizardCategory, pos);
            list.appendChild(btn);
        });
        
        renderPagination(totalPages);
    }

    function renderPagination(totalPages) {
        const pagination = document.getElementById('positionPagination');
        pagination.innerHTML = '';
        
        if (totalPages <= 1) return;
        
        const createEllipsis = () => {
            const li = document.createElement('li');
            li.className = 'page-item disabled';
            li.innerHTML = '<span class="page-link border-0 bg-transparent text-muted">...</span>';
            return li;
        };
        
        const createLi = (text, pageNum, active, isFirst, isLast) => {
            const li = document.createElement('li');
            li.className = `page-item ${active ? 'active' : ''}`;
            const a = document.createElement('a');
            
            let extraClasses = 'rounded-circle';
            if (isFirst) extraClasses = 'page-first';
            else if (isLast) extraClasses = 'page-last';
            
            a.className = `page-link mx-1 ${active ? 'shadow-sm' : ''} ${extraClasses}`;
            a.href = 'javascript:void(0)';
            a.innerHTML = text;
            if (!active) {
                a.onclick = () => filterAndPaginatePositions(pageNum);
            }
            li.appendChild(a);
            return li;
        };

        const paginationList = [];
        for (let i = 1; i <= totalPages; i++) {
            if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) {
                paginationList.push({ page: i, isCurrent: i === currentPage });
            } else if (i === currentPage - 3 || i === currentPage + 3) {
                paginationList.push({ isEllipsis: true });
            }
        }

        const cleanPagination = paginationList.filter((p, index, arr) => {
            if (p.isEllipsis && arr[index - 1] && arr[index - 1].isEllipsis) return false;
            return true;
        });

        cleanPagination.forEach((p, index) => {
            if (p.isEllipsis) {
                pagination.appendChild(createEllipsis());
            } else {
                const isFirst = index === 0;
                const isLast = index === cleanPagination.length - 1;
                pagination.appendChild(createLi(p.page, p.page, p.isCurrent, isFirst, isLast));
            }
        });
    }

    function backToCategories() {
        // Obsolete as categories remain visible
    }

    function backToPositions() {
        document.getElementById('addApplicantTitle').innerHTML = '<i class="bi bi-person-plus-fill me-2"></i>New Applicant Wizard';
        document.getElementById('wizardStep1').classList.add('d-none');
        document.getElementById('wizardStep0').classList.remove('d-none');
    }

    function selectPosition(cat, pos) {
        document.getElementById('wizardCategory').value = cat;
        document.getElementById('wizardPosition').value = pos;
        document.getElementById('selectedPositionText').innerText = `${cat} > ${pos}`;
        document.getElementById('addApplicantTitle').innerHTML = '<i class="bi bi-person-vcard me-2"></i>Applicant Information';
        document.getElementById('wizardStep0').classList.add('d-none');
        document.getElementById('wizardStep1').classList.remove('d-none');
    }

    function nextStep(stepNum) {
        document.querySelectorAll('[id^="wizardStep"]').forEach(el => el.classList.add('d-none'));
        document.getElementById(`wizardStep${stepNum}`).classList.remove('d-none');
    }

    function prevStep(stepNum) {
        document.querySelectorAll('[id^="wizardStep"]').forEach(el => el.classList.add('d-none'));
        document.getElementById(`wizardStep${stepNum}`).classList.remove('d-none');
    }

    const wizardData = {
        education: [],
        training: [],
        experience: [],
        eligibility: []
    };

    function renderWizardList(type) {
        const prefixMap = { education: 'edu', training: 'train', experience: 'exp', eligibility: 'elig' };
        const listDiv = document.getElementById(`${prefixMap[type]}List`);
        if (!listDiv) return;
        
        let html = '<ul class="list-group">';
        if (wizardData[type].length === 0) {
            html += `<li class="list-group-item text-muted small border-0 px-0">No ${type} records added yet.</li>`;
        } else {
            wizardData[type].forEach((item, index) => {
                let text = '';
                if (type === 'education') text = `<strong>${item.degree}</strong> (${item.year})`;
                if (type === 'training') text = `<strong>${item.title}</strong> (${item.hours} hrs)`;
                if (type === 'experience') text = `<strong>${item.details}</strong> (${item.years} yrs)`;
                if (type === 'eligibility') text = `<strong>${item.details}</strong> (Rating: ${item.rating})`;
                
                let linkHtml = item.link ? `<br><a href="${item.link}" target="_blank" class="text-primary text-decoration-none small"><i class="bi bi-link-45deg"></i> View Document</a>` : '';
                
                html += `<li class="list-group-item d-flex justify-content-between align-items-center rounded shadow-sm mb-2">
                    <span>${text}${linkHtml}</span>
                    <button type="button" class="btn btn-sm btn-outline-danger border-0" onclick="removeWizardItem('${type}', ${index})"><i class="bi bi-trash"></i></button>
                </li>`;
            });
        }
        html += '</ul>';
        listDiv.innerHTML = html;
    }

    window.removeWizardItem = (type, index) => {
        wizardData[type].splice(index, 1);
        renderWizardList(type);
    };

    document.getElementById('btn-add-edu')?.addEventListener('click', () => {
        const degree = document.getElementById('edu_degree').value;
        const year = document.getElementById('edu_year').value;
        const link = document.getElementById('edu_link')?.value || '';
        if (degree && year) {
            wizardData.education.push({ degree, year, link });
            document.getElementById('edu_degree').value = '';
            document.getElementById('edu_year').value = '';
            if (document.getElementById('edu_link')) document.getElementById('edu_link').value = '';
            renderWizardList('education');
        } else alert("Please provide degree and year.");
    });

    document.getElementById('btn-add-train')?.addEventListener('click', () => {
        const title = document.getElementById('train_title').value;
        const hours = document.getElementById('train_hours').value;
        const link = document.getElementById('train_link')?.value || '';
        if (title && hours) {
            wizardData.training.push({ title, hours, link });
            document.getElementById('train_title').value = '';
            document.getElementById('train_hours').value = '';
            if (document.getElementById('train_link')) document.getElementById('train_link').value = '';
            renderWizardList('training');
        } else alert("Please provide title and hours.");
    });

    document.getElementById('btn-add-exp')?.addEventListener('click', () => {
        const details = document.getElementById('exp_details').value;
        const years = document.getElementById('exp_years').value;
        const link = document.getElementById('exp_link')?.value || '';
        if (details && years) {
            wizardData.experience.push({ details, years, link });
            document.getElementById('exp_details').value = '';
            document.getElementById('exp_years').value = '';
            if (document.getElementById('exp_link')) document.getElementById('exp_link').value = '';
            renderWizardList('experience');
        } else alert("Please provide details and years.");
    });

    document.getElementById('btn-add-elig')?.addEventListener('click', () => {
        const details = document.getElementById('elig_details').value;
        const rating = document.getElementById('elig_rating').value;
        const link = document.getElementById('elig_link')?.value || '';
        if (details && rating) {
            wizardData.eligibility.push({ details, rating, link });
            document.getElementById('elig_details').value = '';
            document.getElementById('elig_rating').value = '';
            if (document.getElementById('elig_link')) document.getElementById('elig_link').value = '';
            renderWizardList('eligibility');
        } else alert("Please provide details and rating.");
    });

    // Initial render
    ['education', 'training', 'experience', 'eligibility'].forEach(renderWizardList);

    const addAppForm = document.getElementById('addApplicantForm');
    if (addAppForm) {
        addAppForm.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' && e.target.tagName !== 'BUTTON' && e.target.tagName !== 'TEXTAREA') {
                e.preventDefault();
            }
        });
        
        addAppForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = e.target.querySelector('button[type="submit"]');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Saving...';
            btn.disabled = true;

            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());
            
            data.education = JSON.stringify(wizardData.education);
            data.training = JSON.stringify(wizardData.training);
            data.experience = JSON.stringify(wizardData.experience);
            data.eligibility = JSON.stringify(wizardData.eligibility);

        try {
            const res = await fetch('/api/applicants', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            if (res.ok) {
                const responseData = await res.json();
                // Redirect directly to the new applicant's requirement page in step 1
                window.location.href = `/step1/1?search=${encodeURIComponent(data.firstName + ' ' + data.lastName)}`;
            } else {
                alert('Failed to save applicant');
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        } catch (err) {
            console.error(err);
            alert('An error occurred');
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
        });
    }
</script>

{{> modals}}
</div>
</div>
<!-- Bootstrap Bundle with Popper -->
<script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
<!-- Custom Script -->
<script src="/js/requirements.js"></script>
<script src="/js/qualifications.js"></script>
<script src="/js/scores.js"></script>
<script src="/js/assignment.js"></script>
<script src="/js/applicantDetails.js"></script>
<script src="/js/documents.js"></script>
<script src="/js/assessment.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
