{{> header}}

<div class="glass-panel p-4 mb-0 shadow-sm rounded-4 d-print-none">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <h2 class="fw-semibold text-primary mb-0" id="addApplicantTitle"><i class="bi bi-person-plus-fill me-2"></i>New Applicant Wizard</h2>
    </div>
    
    <form id="addApplicantStandaloneForm" novalidate>
        <input type="hidden" id="wizardCategory" name="category">
        <input type="hidden" id="wizardPosition" name="position">
                <!-- Step 0: Category & Position -->
                <div id="wizardStep0">
                    <h6 id="categorySelectionTitle" class="mb-4 text-center fw-bold text-secondary">Select Applicant Category</h6>
                    <div class="row g-3 mb-4" id="categorySelection">
                        {{#each groupedPositions}}
                        <div class="col-sm-6 col-md-3">
                            <button type="button" class="btn btn-outline-primary w-100 py-3 fw-semibold category-btn" data-category="{{this.categoryName}}" style="transition: all 0.3s ease;">
                                {{this.categoryName}}
                            </button>
                        </div>
                        {{/each}}
                    </div>
                    
                    <div id="positionSelection" class="d-none mt-5">
                        <div class="d-flex justify-content-between align-items-center mb-4 mx-auto" style="max-width: 800px;">
                            <h5 class="mb-0 fw-bold text-primary border-bottom border-2 border-primary pb-2 px-3" id="selectedCategoryTitle">Select Position</h5>
                            <div class="input-group shadow-sm" style="width: 250px;">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                                <input type="text" class="form-control border-start-0 ps-0" id="positionSearch" placeholder="Search positions..." oninput="filterAndPaginatePositions(1)">
                            </div>
                        </div>
                        <div class="list-group border rounded-4 shadow-sm mx-auto overflow-hidden" id="positionList" style="max-width: 800px;">
                            <!-- Populated via JS -->
                        </div>
                        <div class="d-flex justify-content-center mt-4">
                            <ul class="pagination pagination-sm shadow-sm" id="positionPagination">
                                <!-- Populated via JS -->
                            </ul>
                        </div>
                    </div>
                </div>
                <div id="wizardStep1" class="d-none">
                    <ul class="nav nav-pills nav-fill mb-4 bg-light rounded-pill p-1 shadow-sm" id="applicantTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active rounded-pill fw-bold" id="tab-personal" data-bs-toggle="pill" data-bs-target="#pane-personal" type="button" role="tab">Personal Info</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link rounded-pill fw-bold" id="tab-eligibility" data-bs-toggle="pill" data-bs-target="#pane-eligibility" type="button" role="tab">Eligibility</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link rounded-pill fw-bold" id="tab-education" data-bs-toggle="pill" data-bs-target="#pane-education" type="button" role="tab">Education</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link rounded-pill fw-bold" id="tab-training" data-bs-toggle="pill" data-bs-target="#pane-training" type="button" role="tab">Training</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link rounded-pill fw-bold" id="tab-experience" data-bs-toggle="pill" data-bs-target="#pane-experience" type="button" role="tab">Experience</button>
                        </li>
                    </ul>

                    <div class="mb-4 d-flex justify-content-between align-items-center">
                        <span class="text-primary fw-semibold" id="selectedPositionText"></span>
                        <button type="button" class="btn btn-sm btn-light border shadow-sm" onclick="backToPositions()"><i class="bi bi-arrow-left"></i> Change Position</button>
                    </div>

                    <div class="tab-content" id="applicantTabsContent">
                        <!-- Personal Info Pane -->
                        <div class="tab-pane show active" id="pane-personal" role="tabpanel">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">First Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" name="firstName" required placeholder="e.g. JOHN" oninput="this.value = this.value.toUpperCase();">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Middle Name</label>
                                    <input type="text" class="form-control" name="middleName" placeholder="e.g. SMITH" oninput="this.value = this.value.toUpperCase();">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Last Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" name="lastName" required placeholder="e.g. DOE" oninput="this.value = this.value.toUpperCase();">
                                </div>
                                
                                <div class="col-md-12 border rounded-3 p-3 bg-light">
                                    <h6 class="text-primary fw-bold mb-3">Residential Address</h6>
                                    <div class="row g-2">
                                        <div class="col-md-3">
                                            <label class="form-label fw-semibold small">House/Block/Lot No.</label>
                                            <input type="text" class="form-control form-control-sm" name="res_house" oninput="this.value = this.value.toUpperCase();">
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-semibold small">Street</label>
                                            <input type="text" class="form-control form-control-sm" name="res_street" oninput="this.value = this.value.toUpperCase();">
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-semibold small">Subdivision/Village</label>
                                            <input type="text" class="form-control form-control-sm" name="res_subdivision" oninput="this.value = this.value.toUpperCase();">
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label fw-semibold small">Barangay <span class="text-danger">*</span></label>
                                            <input type="text" class="form-control form-control-sm" name="res_barangay" required oninput="this.value = this.value.toUpperCase();">
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label fw-semibold small">City/Municipality <span class="text-danger">*</span></label>
                                            <input type="text" class="form-control form-control-sm" name="res_city" required oninput="this.value = this.value.toUpperCase();">
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label fw-semibold small">Province <span class="text-danger">*</span></label>
                                            <input type="text" class="form-control form-control-sm" name="res_province" required oninput="this.value = this.value.toUpperCase();">
                                        </div>
                                        <div class="col-md-4">
                                            <label class="form-label fw-semibold small">Zip Code</label>
                                            <input type="text" class="form-control form-control-sm" name="res_zip" oninput="this.value = this.value.toUpperCase();">
                                        </div>
                                    </div>

                                </div>
                                
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Birthdate <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control" name="birthdate" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Sex <span class="text-danger">*</span></label>
                                    <select class="form-select" name="sex" required>
                                        <option value="">Select...</option>
                                        <option value="Male">Male</option>
                                        <option value="Female">Female</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Civil Status <span class="text-danger">*</span></label>
                                    <select class="form-select" name="civilStatus" required>
                                        <option value="">Select...</option>
                                        <option value="Single">Single</option>
                                        <option value="Married">Married</option>
                                        <option value="Widowed">Widowed</option>
                                        <option value="Separated">Separated</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Religion</label>
                                    <input type="text" class="form-control" name="religion" oninput="this.value = this.value.toUpperCase();">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Disability</label>
                                    <input type="text" class="form-control" name="disability" oninput="this.value = this.value.toUpperCase();" placeholder="N/A if none">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Ethnic Group</label>
                                    <input type="text" class="form-control" name="ethnicGroup" oninput="this.value = this.value.toUpperCase();">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Email Address</label>
                                    <input type="email" class="form-control" name="emailAddress" placeholder="email@example.com">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">Contact No. <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" name="contactNo" placeholder="09XX XXX XXXX" pattern="^09\d{9}$" title="Must start with 09 and be exactly 11 digits long (e.g. 09123456789)" oninput="this.value = this.value.replace(/[^0-9]/g, '');" maxlength="11" required>
                                </div>
                            </div>
                            <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                                <button type="button" class="btn btn-primary px-4 fw-bold shadow-sm" onclick="nextTab('tab-eligibility')">Next <i class="bi bi-arrow-right-circle ms-2"></i></button>
                            </div>
                        </div>

                        <!-- Eligibility Pane -->
                        <div class="tab-pane" id="pane-eligibility" role="tabpanel">
                            <div class="mb-4 pb-3 border-bottom">
                                <h5 class="mb-0 fw-bold text-primary">Eligibility Background</h5>
                                <small class="text-muted">Enter relevant eligibility/licenses</small>
                            </div>
                            <div class="row g-3 align-items-end">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Eligibility Details (e.g. RA 1080)</label>
                                    <input type="text" class="form-control" id="elig_details" placeholder="e.g. RA 1080 (CPA)">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Rating</label>
                                    <input type="text" class="form-control" id="elig_rating" placeholder="e.g. 85.5" oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*?)\..*/g, '$1'); if(parseFloat(this.value) > 100) this.value = 100;">
                                </div>
                                <div class="col-md-2">
                                    <button type="button" class="btn btn-success w-100" id="btn-add-elig">Add Entry <i class="bi bi-plus-circle ms-1"></i></button>
                                </div>
                            </div>
                            <div class="mt-3" id="eligList"></div>
                            <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                                <button type="button" class="btn btn-light border shadow-sm px-4 fw-bold" onclick="nextTab('tab-personal')"><i class="bi bi-arrow-left-circle me-2"></i> Back</button>
                                <button type="button" class="btn btn-primary px-4 fw-bold shadow-sm" onclick="nextTab('tab-education')">Next <i class="bi bi-arrow-right-circle ms-2"></i></button>
                            </div>
                        </div>

                        <!-- Education Pane -->
                        <div class="tab-pane" id="pane-education" role="tabpanel">
                            <div class="mb-4 pb-3 border-bottom">
                                <h5 class="mb-0 fw-bold text-primary">Educational Background</h5>
                                <small class="text-muted">Enter highest or most relevant education</small>
                            </div>
                            <div class="row g-3 align-items-end">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Degree / Course</label>
                                    <input type="text" class="form-control" id="edu_degree" placeholder="e.g. BS Computer Science">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Year Graduated</label>
                                    <input type="number" class="form-control" id="edu_year" min="0" placeholder="e.g. 2020" oninput="this.value = this.value.replace(/[^0-9]/g, '');">
                                </div>
                                <div class="col-md-2">
                                    <button type="button" class="btn btn-success w-100" id="btn-add-edu">Add Entry <i class="bi bi-plus-circle ms-1"></i></button>
                                </div>
                            </div>
                            <div class="mt-3" id="eduList"></div>
                            <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                                <button type="button" class="btn btn-light border shadow-sm px-4 fw-bold" onclick="nextTab('tab-eligibility')"><i class="bi bi-arrow-left-circle me-2"></i> Back</button>
                                <button type="button" class="btn btn-primary px-4 fw-bold shadow-sm" onclick="nextTab('tab-training')">Next <i class="bi bi-arrow-right-circle ms-2"></i></button>
                            </div>
                        </div>

                        <!-- Training Pane -->
                        <div class="tab-pane" id="pane-training" role="tabpanel">
                            <div class="mb-4 pb-3 border-bottom">
                                <h5 class="mb-0 fw-bold text-primary">Training Background</h5>
                                <small class="text-muted">Enter most relevant training</small>
                            </div>
                            <div class="row g-3 align-items-end">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Title of Training</label>
                                    <input type="text" class="form-control" id="train_title" placeholder="e.g. Leadership Seminar">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Number of Hours</label>
                                    <input type="text" class="form-control" id="train_hours" placeholder="e.g. 40" oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*?)\..*/g, '$1');">
                                </div>
                                <div class="col-md-2">
                                    <button type="button" class="btn btn-success w-100" id="btn-add-train">Add Entry <i class="bi bi-plus-circle ms-1"></i></button>
                                </div>
                            </div>
                            <div class="mt-3" id="trainList"></div>
                            <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                                <button type="button" class="btn btn-light border shadow-sm px-4 fw-bold" onclick="nextTab('tab-education')"><i class="bi bi-arrow-left-circle me-2"></i> Back</button>
                                <button type="button" class="btn btn-primary px-4 fw-bold shadow-sm" onclick="nextTab('tab-experience')">Next <i class="bi bi-arrow-right-circle ms-2"></i></button>
                            </div>
                        </div>

                        <!-- Experience Pane -->
                        <div class="tab-pane" id="pane-experience" role="tabpanel">
                            <div class="mb-4 pb-3 border-bottom">
                                <h5 class="mb-0 fw-bold text-primary">Experience Background</h5>
                                <small class="text-muted">Enter most relevant experience</small>
                            </div>
                            <div class="row g-3 align-items-end">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Experience Details (Company & Role)</label>
                                    <input type="text" class="form-control" id="exp_details" placeholder="e.g. Software Engineer at Tech Corp">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Number of Years</label>
                                    <input type="text" class="form-control" id="exp_years" placeholder="e.g. 2.5" oninput="this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\..*?)\..*/g, '$1');">
                                </div>
                                <div class="col-md-2">
                                    <button type="button" class="btn btn-success w-100" id="btn-add-exp">Add Entry <i class="bi bi-plus-circle ms-1"></i></button>
                                </div>
                            </div>
                            <div class="mt-3" id="expList"></div>
                            <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                                <button type="button" class="btn btn-light border shadow-sm px-4 fw-bold" onclick="nextTab('tab-training')"><i class="bi bi-arrow-left-circle me-2"></i> Back</button>
                                <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">Save Applicant <i class="bi bi-check-circle ms-2"></i></button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
</div>

<script>
    // Make positions map available to frontend
    window.dynamicPositionsByCategory = {
        {{#each groupedPositions}}
        "{{this.categoryName}}": [
            {{#each this.positions}}
            "{{this.title}}",
            {{/each}}
        ]{{#unless @last}},{{/unless}}
        {{/each}}
    };
</script>
<script src="/js/addApplicant.js?v=2"></script>

{{> index_modals}}
</div>
</div>

<!-- Custom Script -->

<script src="/js/requirements.js"></script>
<script src="/js/qualifications.js"></script>
<script src="/js/assignment.js"></script>
<script src="/js/applicantDetails.js"></script>
<script src="/js/documents.js"></script>
<script src="/js/assessment.js"></script>
<script src="/js/main.js"></script>
<script src="/js/modal_stack.js"></script>
    {{> global_toasts}}
    <script src="/js/utils.js"></script>
</body>
</html>
